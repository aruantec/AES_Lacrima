    <PackageLicenseFile>LICENSE</PackageLicenseFile>
    <Version>0.0.2-beta</Version>
    <Description>mpv csharp binding code</Description>
    <PackageTags>mpv</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <None Include="LICENSE" Pack="true" PackagePath="" />
  </ItemGroup>

</Project>
