<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:emulation="using:AES_Emulation.Windows"
    xmlns:vm="using:AES_Lacrima.ViewModels"
        x:Class="AES_Lacrima.Views.PortalWindow"
    x:DataType="vm:EmulationViewModel"
        Title="PortalWindow"
        Background="#0F0F0F"
        WindowDecorations="None"
        CanResize="False"
        ShowInTaskbar="False"
        Topmost="False"
        TransparencyLevelHint="None"
        WindowStartupLocation="Manual">
    <Grid ClipToBounds="True">
        <Border Background="#0F0F0F"/>
        <emulation:WgcCaptureControl x:Name="CaptureControl"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Stretch"
                                     TargetHwnd="{Binding EmulatorTargetHwnd}"
                                     RetroarchShaderFile="{Binding SelectedShaderFileItem.Path, Mode=TwoWay}"
                                     Stretch="{Binding SelectedStretch, Mode=TwoWay}"
                                     ForceUseTargetClientSize="True"
                                     DisableVSync="{Binding DisableVSync, Mode=TwoWay}"
                                     Brightness="{Binding RenderBrightness, Mode=TwoWay}"
                                     Saturation="{Binding RenderSaturation, Mode=TwoWay}"
                                     ShowStatisticsOverlay="{Binding ShowStatisticsOverlay, Mode=TwoWay}"
                                     ShowFrametimeGraph="{Binding ShowFrametimeGraph, Mode=TwoWay}"
                                     ShowDetailedGpuInfo="{Binding ShowDetailedGpuInfo, Mode=TwoWay}"
                                     OverlayOpacity="{Binding RenderOverlayOpacity, Mode=TwoWay}"
                                     RequestStopSession="{Binding RequestStopEmulatorCapture, Mode=TwoWay}" />

        <Border Margin="16"
                Padding="10"
                CornerRadius="8"
                Background="#C0000000"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                IsHitTestVisible="False"
                Opacity="{Binding RenderOverlayOpacity}">
            <Border.IsVisible>
                <Binding Path="ShowStatisticsOverlay"/>
            </Border.IsVisible>
            <StackPanel Spacing="4"
                        HorizontalAlignment="Left">
                <TextBlock Text="{Binding ElementName=CaptureControl, Path=BackendName, StringFormat='Backend: {0}'}"
                           Foreground="White"
                           FontSize="16"
                           FontFamily="Consolas"/>
                <TextBlock Text="{Binding ElementName=CaptureControl, Path=Fps, StringFormat='FPS: {0:0.0}'}"
                           Foreground="White"
                           FontSize="16"
                           FontFamily="Consolas"/>
                <TextBlock Text="{Binding ElementName=CaptureControl, Path=FrameTimeMs, StringFormat='FrameTime: {0:0.00} ms'}"
                           Foreground="White"
                           FontSize="16"
                           FontFamily="Consolas"/>
                <StackPanel Spacing="4"
                            HorizontalAlignment="Left"
                            IsVisible="{Binding ShowDetailedGpuInfo}">
                    <TextBlock Text="{Binding ElementName=CaptureControl, Path=GpuRenderer, StringFormat='GPU: {0}'}"
                               Foreground="#DDDDDD"
                               FontSize="13"
                               FontFamily="Consolas"
                               HorizontalAlignment="Left"
                               TextAlignment="Left"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="340"/>
                    <TextBlock Text="{Binding ElementName=CaptureControl, Path=GpuVendor, StringFormat='Vendor: {0}'}"
                               Foreground="#DDDDDD"
                               FontSize="13"
                               FontFamily="Consolas"
                               HorizontalAlignment="Left"
                               TextAlignment="Left"/>
                </StackPanel>
                <StackPanel Spacing="0"
                            HorizontalAlignment="Left"
                            IsVisible="{Binding ShowFrametimeGraph}">
                    <Canvas Width="{Binding ElementName=CaptureControl, Path=FrametimeGraphWidth}"
                            Height="40"
                            HorizontalAlignment="Left"
                            Margin="0,5,0,0">
                        <Border Width="{Binding ElementName=CaptureControl, Path=FrametimeGraphWidth}"
                                Height="1"
                                Background="#28FFFFFF"
                                Canvas.Top="13.36"/>
                        <Border Width="{Binding ElementName=CaptureControl, Path=FrametimeGraphWidth}"
                                Height="1"
                                Background="#28FFFFFF"
                                Canvas.Top="26.72"/>
                        <Path Data="{Binding ElementName=CaptureControl, Path=FrametimeGraphGeometry}"
                              Stroke="#B400FFFF"
                              StrokeThickness="1.5"
                              Stretch="None"/>
                        <TextBlock Text="{Binding ElementName=CaptureControl, Path=FrameTimeMs, StringFormat='{}{0:0.00} ms'}"
                                   Foreground="#FF00FFFF"
                                   FontSize="12"
                                   FontFamily="Consolas"
                                   Canvas.Top="-5"
                                   Canvas.Left="0"/>
                    </Canvas>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
