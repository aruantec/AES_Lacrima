<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:composition="using:AES_Controls.Composition"
             xmlns:emulation="using:AES_Emulation.Windows"
             xmlns:navigation="using:AES_Lacrima.Views.Navigation"
             xmlns:behaviors="using:AES_Lacrima.Behaviors"
             xmlns:controlBehaviors="using:AES_Controls.Behaviors"
             xmlns:media="using:Avalonia.Media"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:Interaction="http://avaloniaui.net/schemas/2019/interactivity"
             xmlns:common="using:AES_Lacrima"
             xmlns:controls="using:AES_Controls"
             xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             xmlns:services="using:AES_Lacrima.Services"
             xmlns:player="using:AES_Controls.Player"
             xmlns:vm="using:AES_Lacrima.ViewModels"
             xmlns:views="using:AES_Lacrima.Views"
             xmlns:emuControls="using:AES_Emulation.Controls"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             x:Name="RootView"
             x:Class="AES_Lacrima.Views.EmulationView"
             x:DataType="vm:EmulationViewModel">

    <Design.DataContext>
        <vm:EmulationViewModel/>
    </Design.DataContext>

    <Interaction.Behaviors>
        <behaviors:CloseOnClickOutsideBehavior 
            TargetControl="{Binding #RenderOptionsOverlay}"
            IsEnabled="{Binding IsRenderOptionsOpen}"
            CloseCommand="{Binding ToggleRenderOptionsCommand}" />
        <behaviors:CloseOnClickOutsideBehavior 
            TargetControl="{Binding #RetroArchErrorOverlay}"
            IsEnabled="{Binding IsRetroArchErrorOverlayOpen}"
            CloseCommand="{Binding ToggleRetroArchErrorOverlayCommand}" />
        <behaviors:CloseOnClickOutsideBehavior 
            TargetControl="{Binding #EmulatorUpdateNoticeOverlay}"
            IsEnabled="{Binding IsEmulatorUpdateNoticeOverlayOpen}"
            CloseCommand="{Binding DismissEmulatorUpdateNoticeOverlayCommand}" />
    </Interaction.Behaviors>

    <Grid RowDefinitions="*,Auto,Auto" ClipToBounds="False">
        <Grid.Styles>
            <Style Selector="Border#RenderOptionsOverlay">
                <Setter Property="Transitions">
                    <Setter.Value>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.30" Easing="CubicEaseInOut" />
                        </Transitions>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style Selector="Border#PortalFallbackOverlay">
                <Setter Property="Transitions">
                    <Setter.Value>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.20" Easing="CubicEaseOut" />
                        </Transitions>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Styles>
        <Border Background="#FF000000" Grid.RowSpan="3"/>
        <!--Removes the background on purpose and forces transparency-->
        <composition:TransparentComposition x:Name="PortalPortal"
                            IsHitTestVisible="False"
                            Opacity="{Binding ElementName=RootView, Path=IsPortalSurfaceVisible, Converter={StaticResource BoolToOpacityConverter}}">
            <composition:TransparentComposition.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.30" Easing="CubicEaseOut" />
                </Transitions>
            </composition:TransparentComposition.Transitions>
        </composition:TransparentComposition>
        <Border x:Name="PortalFallbackOverlay"
                Background="#FF000000"
                IsHitTestVisible="False"
                Opacity="{Binding ElementName=RootView, Path=PortalFallbackOpacity}"/>

        <composition:CompositionCarouselControl x:Name="RomCarousel"
                                                ItemsSource="{Binding CoverItems}"
                                                ImageBitmapProperty="CoverBitmap"
                                                ImageFileNameProperty="LocalCoverPath"
                                                PublishSelectedItemBounds="{Binding IsGameplayPreviewViewportVisible}"
                                                SelectedIndex="{Binding SelectedIndex, Mode=TwoWay}"
                                                PointedItemIndex="{Binding PointedIndex, Mode=TwoWay}"
                                                ItemDoubleClickedCommand="{Binding OpenSelectedItemCommand}"
                                                ShowCoverFoundOverlay="False"
                                                ItemSpacing="{Binding SettingsViewModel.CarouselSpacing}"
                                                ItemScale="{Binding SettingsViewModel.CarouselScale}"
                                                VerticalOffset="{Binding SettingsViewModel.CarouselVerticalOffset}"
                                                SliderVerticalOffset="{Binding SettingsViewModel.CarouselSliderVerticalOffset}"
                                                SliderTrackHeight="{Binding SettingsViewModel.CarouselSliderTrackHeight}"
                                                SideTranslation="{Binding SettingsViewModel.CarouselSideTranslation}"
                                                StackSpacing="{Binding SettingsViewModel.CarouselStackSpacing}"
                                                UseFullCoverSize="{Binding SettingsViewModel.CarouselUseFullCoverSize}"
                                                IsHitTestVisible="{Binding !IsEmulatorViewportVisible}"
                                                Opacity="{Binding ElementName=RootView, Path=CarouselOpacity}"
                                                GlobalOpacity="{Binding IsActive, Converter={StaticResource BoolToOpacityConverter}}"
                                                ClipToBounds="False">
            <composition:CompositionCarouselControl.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.24" Easing="CubicEaseOut" />
                </Transitions>
            </composition:CompositionCarouselControl.Transitions>
            <composition:CompositionCarouselControl.ContextMenu>
                <ContextMenu Background="#AA000000" BorderBrush="#44FFFFFF" BorderThickness="0.5" CornerRadius="8" Padding="0">
                    <MenuItem Header="Add Roms" CornerRadius="8" Command="{Binding AddRomsCommand}">
                        <MenuItem.Icon>
                            <Viewbox Width="32" Height="32" Stretch="Uniform">
                                <Canvas Width="100" Height="100">
                                    <Rectangle Canvas.Left="2" Canvas.Top="2" Width="96" Height="96" RadiusX="22" RadiusY="22" Stroke="#CCFFFFFF" StrokeThickness="8" Fill="Transparent" />
                                    <Rectangle Canvas.Left="46" Canvas.Top="32" Width="8" Height="36" RadiusX="4" RadiusY="4" Fill="#CCFFFFFF" />
                                    <Rectangle Canvas.Left="32" Canvas.Top="46" Width="36" Height="8" RadiusX="4" RadiusY="4" Fill="#CCFFFFFF" />
                                </Canvas>
                            </Viewbox>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Scan Folder" CornerRadius="8" Command="{Binding ScanFolderCommand}">
                        <MenuItem.Icon>
                            <Viewbox Width="32" Height="32" Stretch="Uniform">
                                <Canvas Width="100" Height="100">
                                    <Path Data="M 10,28 L 10,78 Q 10,84 16,84 L 84,84 Q 90,84 90,78 L 90,38 Q 90,32 84,32 L 46,32 L 34,22 L 16,22 Q 10,22 10,28"
                                          Stroke="#CCFFFFFF"
                                          StrokeThickness="6"
                                          Fill="Transparent" />
                                    <Ellipse Canvas.Left="48" Canvas.Top="46"
                                             Width="22"
                                             Height="22"
                                             Stroke="#CCFFFFFF"
                                             StrokeThickness="6"
                                             Fill="Transparent" />
                                    <Line StartPoint="66,64"
                                          EndPoint="82,80"
                                          Stroke="#CCFFFFFF"
                                          StrokeThickness="6"
                                          StrokeLineCap="Round" />
                                </Canvas>
                            </Viewbox>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Clear Album"
                              CornerRadius="8"
                              Command="{Binding ClearAlbumCommand}"
                              IsVisible="{Binding HasActiveAlbumItems}">
                        <MenuItem.Icon>
                            <Path Data="M6,19A2,2 0 0,0 8,21h8a2,2 0 0,0 2-2V7H6v12zM19,4h-3.5l-1-1h-5l-1,1H5v2h14V4z"
                                  Fill="#CCFFFFFF"
                                  Width="32"
                                  Height="32"
                                  Stretch="Uniform"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Edit Metadata"
                              CornerRadius="8"
                              Command="{Binding OpenMetadataCommand}"
                              CommandParameter="{Binding PointedIndex}"
                              IsVisible="{Binding HasActiveAlbumItems}">
                        <MenuItem.Icon>
                            <Path Data="M18,34 C18,30.69 20.69,28 24,28 H120 C123.31,28 126,30.69 126,34 C126,37.31 123.31,40 120,40 H24 C20.69,40 18,37.31 18,34 M18,58 C18,54.69 20.69,52 24,52 H120 C123.31,52 126,54.69 126,58 C126,61.31 123.31,64 120,64 H24 C20.69,64 18,61.31 18,58 M18,82 C18,78.69 20.69,76 24,76 H88 C91.31,76 94,78.69 94,82 C94,85.31 91.31,88 88,88 H24 C20.69,88 18,85.31 18,82 M152.4,69.5 L114.7,107.2 C113.1,108.8 110.8,111.9 109.5,114.2 L105.1,122 C103.5,124.9 104,128.5 106.3,130.8 C108.6,133.1 112.2,133.6 115.1,132 L122.9,127.6 C125.2,126.3 128.3,124 129.9,122.4 L167.6,84.7 C169.2,83.1 169.2,80.5 167.6,78.9 L158.2,69.5 C156.6,67.9 154,67.9 152.4,69.5 M147,94.5 C145.4,92.9 145.4,90.3 147,88.7 L150,85.7 C151.6,84.1 154.2,84.1 155.8,85.7 L158.8,88.7 C160.4,90.3 160.4,92.9 158.8,94.5 L147,94.5 Z"
                                  Fill="#CCFFFFFF"
                                  Width="32"
                                  Height="32"
                                  Stretch="Uniform" />
                        </MenuItem.Icon>
                    </MenuItem>
                     <MenuItem Header="Patches"
                               CornerRadius="8"
                               Command="{Binding OpenCurrentSectionXeniaPatchesCommand}"
                               CommandParameter="{Binding SelectedIndex}"
                               IsVisible="{Binding ShowCurrentSectionXeniaPatchesMenuItem}">
                         <MenuItem.Icon>
                             <Path Data="M22,30 H118 C124,30 128,34 128,40 V116 C128,122 124,126 118,126 H22 C16,126 12,122 12,116 V40 C12,34 16,30 22,30 Z M24,46 H116 V110 H24 Z M34,56 H54 V76 H34 Z M62,56 H82 V76 H62 Z M90,56 H110 V76 H90 Z M34,84 H54 V104 H34 Z M62,84 H82 V104 H62 Z M90,84 H110 V104 H90 Z"
                                   Fill="#CCFFFFFF"
                                   Width="32"
                                   Height="32"
                                   Stretch="Uniform" />
                         </MenuItem.Icon>
                     </MenuItem>
                     <MenuItem Header="Custom Config"
                               CornerRadius="8"
                               Command="{Binding OpenCurrentSectionXeniaCustomConfigCommand}"
                               CommandParameter="{Binding SelectedIndex}"
                               IsVisible="{Binding ShowCurrentSectionXeniaCustomConfigMenuItem}">
                         <MenuItem.Icon>
                             <Path Data="M20,18 H44 V30 H20 Z M56,18 H80 V30 H56 Z M92,18 H116 V30 H92 Z M20,42 H44 V54 H20 Z M56,42 H80 V54 H56 Z M92,42 H116 V54 H92 Z M20,66 H44 V78 H20 Z M56,66 H80 V78 H56 Z M92,66 H116 V78 H92 Z"
                                   Fill="#CCFFFFFF"
                                   Width="32"
                                   Height="32"
                                   Stretch="Uniform" />
                         </MenuItem.Icon>
                     </MenuItem>
                     <MenuItem Header="Custom Config"
                               CornerRadius="8"
                               Command="{Binding OpenCurrentSectionRpcs3CustomConfigCommand}"
                               CommandParameter="{Binding SelectedIndex}"
                               IsVisible="{Binding ShowCurrentSectionRpcs3CustomConfigMenuItem}">
                         <MenuItem.Icon>
                             <Path Data="M20,18 H44 V30 H20 Z M56,18 H80 V30 H56 Z M92,18 H116 V30 H92 Z M20,42 H44 V54 H20 Z M56,42 H80 V54 H56 Z M92,42 H116 V54 H92 Z M20,66 H44 V78 H20 Z M56,66 H80 V78 H56 Z M92,66 H116 V78 H92 Z"
                                   Fill="#CCFFFFFF"
                                   Width="32"
                                   Height="32"
                                   Stretch="Uniform" />
                         </MenuItem.Icon>
                     </MenuItem>
                     <MenuItem Header="Graphic Packs"
                               CornerRadius="8"
                               Command="{Binding OpenCurrentSectionCemuGraphicPacksCommand}"
                               CommandParameter="{Binding SelectedIndex}"
                               IsVisible="{Binding ShowCurrentSectionCemuGraphicPacksMenuItem}">
                         <MenuItem.Icon>
                             <Path Data="M22,30 H118 C124,30 128,34 128,40 V116 C128,122 124,126 118,126 H22 C16,126 12,122 12,116 V40 C12,34 16,30 22,30 Z M24,46 H116 V110 H24 Z M34,56 H54 V76 H34 Z M62,56 H82 V76 H62 Z M90,56 H110 V76 H90 Z M34,84 H54 V104 H34 Z M62,84 H82 V104 H62 Z M90,84 H110 V104 H90 Z"
                                   Fill="#CCFFFFFF"
                                   Width="32"
                                   Height="32"
                                   Stretch="Uniform" />
                         </MenuItem.Icon>
                     </MenuItem>
                     <MenuItem Header="Patches"
                               CornerRadius="8"
                               Command="{Binding OpenCurrentSectionRpcs3PatchesCommand}"
                               CommandParameter="{Binding SelectedIndex}"
                               IsVisible="{Binding ShowCurrentSectionRpcs3PatchesMenuItem}">
                         <MenuItem.Icon>
                             <Path Data="M22,30 H118 C124,30 128,34 128,40 V116 C128,122 124,126 118,126 H22 C16,126 12,122 12,116 V40 C12,34 16,30 22,30 Z M24,46 H116 V110 H24 Z M34,56 H54 V76 H34 Z M62,56 H82 V76 H62 Z M90,56 H110 V76 H90 Z M34,84 H54 V104 H34 Z M62,84 H82 V104 H62 Z M90,84 H110 V104 H90 Z"
                                   Fill="#CCFFFFFF"
                                   Width="32"
                                   Height="32"
                                   Stretch="Uniform" />
                         </MenuItem.Icon>
                     </MenuItem>
                     <MenuItem Header="Cheats"
                               CornerRadius="8"
                               Command="{Binding OpenCurrentSectionRpcs3CheatsCommand}"
                               CommandParameter="{Binding SelectedIndex}"
                               IsVisible="{Binding ShowCurrentSectionRpcs3CheatsMenuItem}">
                         <MenuItem.Icon>
                             <Path Data="M70,24 C44,24 24,44 24,70 C24,96 44,116 70,116 C96,116 116,96 116,70 C116,44 96,24 70,24 Z M70,36 C89,36 104,51 104,70 C104,89 89,104 70,104 C51,104 36,89 36,70 C36,51 51,36 70,36 Z M58,58 H82 V64 H58 Z M58,72 H82 V78 H58 Z"
                                   Fill="#CCFFFFFF"
                                   Width="32"
                                   Height="32"
                                   Stretch="Uniform" />
                         </MenuItem.Icon>
                     </MenuItem>
                     <MenuItem Header="Patches"
                               CornerRadius="8"
                               Command="{Binding OpenCurrentSectionShadPs4PatchesCommand}"
                               CommandParameter="{Binding SelectedIndex}"
                               IsVisible="{Binding ShowCurrentSectionShadPs4PatchesMenuItem}">
                         <MenuItem.Icon>
                             <Path Data="M22,30 H118 C124,30 128,34 128,40 V116 C128,122 124,126 118,126 H22 C16,126 12,122 12,116 V40 C12,34 16,30 22,30 Z M24,46 H116 V110 H24 Z M34,56 H54 V76 H34 Z M62,56 H82 V76 H62 Z M90,56 H110 V76 H90 Z M34,84 H54 V104 H34 Z M62,84 H82 V104 H62 Z M90,84 H110 V104 H90 Z"
                                   Fill="#CCFFFFFF"
                                   Width="32"
                                   Height="32"
                                   Stretch="Uniform" />
                         </MenuItem.Icon>
                     </MenuItem>
                     <MenuItem Header="Custom Config"
                               CornerRadius="8"
                               Command="{Binding OpenCurrentSectionShadPs4CustomConfigCommand}"
                               CommandParameter="{Binding SelectedIndex}"
                               IsVisible="{Binding ShowCurrentSectionShadPs4CustomConfigMenuItem}">
                         <MenuItem.Icon>
                             <Path Data="M20,18 H44 V30 H20 Z M56,18 H80 V30 H56 Z M92,18 H116 V30 H92 Z M20,42 H44 V54 H20 Z M56,42 H80 V54 H56 Z M92,42 H116 V54 H92 Z M20,66 H44 V78 H20 Z M56,66 H80 V78 H56 Z M92,66 H116 V78 H92 Z"
                                   Fill="#CCFFFFFF"
                                   Width="32"
                                   Height="32"
                                   Stretch="Uniform" />
                         </MenuItem.Icon>
                     </MenuItem>
                     <MenuItem Header="Cheats"
                               CornerRadius="8"
                               Command="{Binding OpenCurrentSectionShadPs4CheatsCommand}"
                               CommandParameter="{Binding SelectedIndex}"
                               IsVisible="{Binding ShowCurrentSectionShadPs4CheatsMenuItem}">
                         <MenuItem.Icon>
                             <Path Data="M22,30 H118 C124,30 128,34 128,40 V116 C128,122 124,126 118,126 H22 C16,126 12,122 12,116 V40 C12,34 16,30 22,30 Z M34,56 H54 V76 H34 Z M62,56 H82 V76 H62 Z M90,56 H110 V76 H90 Z M34,84 H54 V104 H34 Z M62,84 H82 V104 H62 Z M90,84 H110 V104 H90 Z"
                                   Fill="#CCFFFFFF"
                                   Width="32"
                                   Height="32"
                                   Stretch="Uniform" />
                         </MenuItem.Icon>
                     </MenuItem>
                     <MenuItem Header="Delete Item"
                               CornerRadius="8"
                               Command="{Binding DeleteItemCommand}"
                               CommandParameter="{Binding PointedIndex}"
                               IsVisible="{Binding IsItemPointed}">
                        <MenuItem.Icon>
                            <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19V4M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                                  Fill="#CCFFFFFF"
                                  Width="32"
                                  Height="32"
                                  Stretch="Uniform"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Clear Album Cache"
                              CornerRadius="8"
                              Command="{Binding ClearAlbumCacheCommand}"
                              IsVisible="{Binding HasActiveAlbumItems}">
                        <MenuItem.Icon>
                            <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14h2v2h-2zm0-10h2v8h-2z"
                                  Fill="#CCFFFFFF"
                                  Width="32"
                                  Height="32"
                                  Stretch="Uniform"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </composition:CompositionCarouselControl.ContextMenu>
        </composition:CompositionCarouselControl>

        <Canvas Grid.Row="0" IsHitTestVisible="False">
            <Border IsVisible="{Binding IsGameplayPreviewViewportVisible}"
                    Canvas.Left="{Binding SelectedItemBounds.X, ElementName=RomCarousel}"
                    Canvas.Top="{Binding SelectedItemBounds.Y, ElementName=RomCarousel}"
                    Width="{Binding SelectedItemBounds.Width, ElementName=RomCarousel}"
                    Height="{Binding SelectedItemBounds.Height, ElementName=RomCarousel}"
                    Margin="-8,-6,0,0"
                    ClipToBounds="False"
                    Opacity="{Binding IsGameplayPreviewViewportVisible, Converter={StaticResource BoolToOpacityConverter}}"
                    Background="Transparent">
                <Border.Transitions>
                    <Transitions>
                        <DoubleTransition Property="Opacity" Duration="0:0:0.45" Easing="CubicEaseOut" />
                    </Transitions>
                </Border.Transitions>
                <Border Height="{Binding SelectedItemBounds.Height, ElementName=RomCarousel}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#FF000000"
                        ClipToBounds="True"
                        RenderTransformOrigin="0.5,0">
                    <Border.Width>
                        <MultiBinding Converter="{StaticResource GameplayPreviewWidthConverter}">
                            <Binding Path="SelectedItemBounds.Width" ElementName="RomCarousel" />
                            <Binding Path="SelectedItemBounds.Height" ElementName="RomCarousel" />
                            <Binding Path="GameplayPreviewTargetAspectRatio" />
                        </MultiBinding>
                    </Border.Width>
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="1.03" ScaleY="1.03" />
                    </Border.RenderTransform>
                    <Border.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Width" Duration="0:0:0.8" Easing="SineEaseInOut" />
                        </Transitions>
                    </Border.Transitions>
                    <player:VideoViewControl x:Name="GameplayVideo"
                                             Player="{Binding AudioPlayer}"
                                             Stretch="Uniform"
                                             ReferenceViewportWidth="{Binding SelectedItemBounds.Width, ElementName=RomCarousel}"
                                             ReferenceViewportHeight="{Binding SelectedItemBounds.Height, ElementName=RomCarousel}"
                                             IsRenderingPaused="{Binding !IsGameplayVideoSurfaceVisible}"
                                             Opacity="{Binding IsGameplayVideoSurfaceVisible, Converter={StaticResource BoolToOpacityConverter}}">
                        <player:VideoViewControl.Transitions>
                            <Transitions>
                                <DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="SineEaseOut" />
                            </Transitions>
                        </player:VideoViewControl.Transitions>
                    </player:VideoViewControl>
                </Border>
            </Border>
        </Canvas>

        <Grid Grid.Row="0"
              Opacity="{Binding IsActive, Converter={StaticResource BoolToOpacityConverter}}"
              ZIndex="5"
              Margin="{Binding IsRenderOptionsOpen, Converter={StaticResource BoolToValueConverter}, ConverterParameter='0,0,660,0'}">
            <Grid.IsHitTestVisible>
                <MultiBinding Converter="{StaticResource BoolOrConverter}">
                    <Binding Path="IsCompositionCaptureVisible"/>
                    <Binding Path="IsRenderOptionsOpen"/>
                    <Binding Path="IsRetroArchErrorOverlayOpen"/>
                </MultiBinding>
            </Grid.IsHitTestVisible>
            <Grid.IsVisible>
                <MultiBinding Converter="{StaticResource BoolOrConverter}">
                    <Binding Path="IsCompositionCaptureVisible"/>
                    <Binding Path="IsEmulatorLaunchInProgress"/>
                    <Binding ElementName="RootView" Path="IsPortalCaptureInitializing"/>
                    <Binding Path="IsRenderOptionsOpen"/>
                </MultiBinding>
            </Grid.IsVisible>
            <Grid.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.45" Easing="CubicEaseOut" />
                </Transitions>
            </Grid.Transitions>
            <Border x:Name="EmulatorCaptureHost"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="Transparent"
                    ClipToBounds="True">
                <emuControls:EmulatorCaptureHost x:Name="InlineCaptureControl"
                                                 IsVisible="False"
                                                 HorizontalAlignment="Stretch"
                                                 VerticalAlignment="Stretch"
                                                 TargetHwnd="{Binding EmulatorTargetHwnd}"
                                                 TargetProcessId="{Binding EmulatorTargetProcessId}"
                                                 TargetWindowTitleHint="{Binding CurrentEmulatorWindowTitleHint}"
                                                 ForceUseTargetClientArea="{Binding ForceUseTargetClientAreaCapture}"
                                                 EnablePillarboxCrop="{Binding EnableCapturePillarboxCrop}"
                                                 ClientAreaCropLeftInset="{Binding ClientAreaCropLeftInset}"
                                                 ClientAreaCropTopInset="{Binding ClientAreaCropTopInset}"
                                                 ClientAreaCropRightInset="{Binding ClientAreaCropRightInset}"
                                                 ClientAreaCropBottomInset="{Binding ClientAreaCropBottomInset}"
                                                 CaptureWindowAspectRatio="{Binding CaptureWindowAspectRatio}"
                                                 HideTargetWindowAfterCaptureStarts="{Binding HideTargetWindowAfterCaptureStarts}"
                                                 Stretch="{Binding CurrentCaptureStretch}"
                                                 Brightness="{Binding PortalCaptureBrightness, Mode=TwoWay}"
                                                 Saturation="{Binding RenderSaturation, Mode=TwoWay}"
                                                 DisableVSync="{Binding DisableVSync, Mode=TwoWay}"
                                                 LowLatencyCapture="{Binding LowLatencyCapture, Mode=TwoWay}"
                                                 FrameGenerationMode="{Binding FrameGenerationMode, Mode=TwoWay}"
                                                 ShaderPath="{Binding SelectedShaderPath}"
                                                 ClearShaderWhenPathEmpty="{Binding ClearShaderWhenPathEmpty}"
                                                 RequestStopSession="{Binding RequestStopEmulatorCapture, Mode=TwoWay}"
                                                 CaptureMode="{Binding SelectedCaptureMode}" />
            </Border>

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="10"
                        Margin="0,0,0,12"
                        IsHitTestVisible="False"
                        ZIndex="1400">
                <StackPanel.IsVisible>
                    <MultiBinding Converter="{StaticResource BoolOrConverter}">
                        <Binding Path="IsEmulatorLaunchInProgress"/>
                        <Binding ElementName="RootView" Path="IsPortalCaptureInitializing"/>
                    </MultiBinding>
                </StackPanel.IsVisible>
                <controls:LoadingControl Width="80"
                                         Height="80"
                                         Foreground="White" />
                <TextBlock Text="Launching emulator..."
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />
            </StackPanel>

            <views:PortalCaptureStatsOverlay x:Name="CaptureStatsOverlay"
                                             CaptureHost="{Binding #RootView}"
                                             Settings="{Binding}"
                                             IsVisible="{Binding !IsFullscreen}"
                                             ZIndex="1500"/>

            <Border x:Name="RenderOptionsOverlay"
                    Background="#B0000000"
                    BorderBrush="DimGray"
                    BorderThickness="0.5,0,0,0"
                    Width="660"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Margin="0,0,0,0"
                    ZIndex="2100"
                    Opacity="{Binding IsRenderOptionsOpen, Converter={StaticResource BoolToOpacityConverter}}"
                    IsHitTestVisible="{Binding IsRenderOptionsOpen}">
                <ScrollViewer Grid.Row="0"
                              Margin="0,40,0,0"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <Grid Margin="25,0,25,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid ColumnDefinitions="*,Auto" Grid.Row="0">
                            <TextBlock Text="Render Options"
                                       FontSize="26"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       VerticalAlignment="Center" />
                        </Grid>

                        <TabControl Grid.Row="1" Margin="0,16,0,0" SelectedIndex="{Binding RenderOptionsSelectedTabIndex, Mode=TwoWay}">
                            <TabItem Header="Rendering">
                                <ScrollViewer>
                                    <StackPanel Margin="0,12,0,0" Spacing="12">
                                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                            <TextBlock Text="Stretch" Foreground="White" VerticalAlignment="Center" FontSize="18" Width="220"/>
                                            <ComboBox MinWidth="220"
                                                      HorizontalAlignment="Stretch"
                                                      ItemsSource="{Binding CaptureStretchOptions}"
                                                      SelectedItem="{Binding SelectedStretch, Mode=TwoWay}">
                                                <Interaction.Behaviors>
                                                    <controlBehaviors:ComboBoxPopupScaler/>
                                                </Interaction.Behaviors>
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                        <TextBlock Text="Brightness" Foreground="White" VerticalAlignment="Center" FontSize="18" Width="220"/>
                                        <Slider Width="280"
                                                Minimum="0.25"
                                                Maximum="2.0"
                                                SmallChange="0.01"
                                                LargeChange="0.1"
                                                Value="{Binding RenderBrightness, Mode=TwoWay}" />
                                        <TextBlock Text="{Binding RenderBrightness, StringFormat='{}{0:0.00}'}"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"
                                                   Width="60"
                                                   FontSize="16"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                        <TextBlock Text="Saturation" Foreground="White" VerticalAlignment="Center" FontSize="18" Width="220"/>
                                        <Slider Width="280"
                                                Minimum="0"
                                                Maximum="2"
                                                SmallChange="0.01"
                                                LargeChange="0.1"
                                                Value="{Binding RenderSaturation, Mode=TwoWay}" />
                                        <TextBlock Text="{Binding RenderSaturation, StringFormat='{}{0:0.00}'}"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"
                                                   Width="60"
                                                   FontSize="16"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                        <TextBlock Text="Overlay Opacity" Foreground="White" VerticalAlignment="Center" FontSize="18" Width="220"/>
                                        <Slider Width="280"
                                                Minimum="0"
                                                Maximum="1"
                                                SmallChange="0.01"
                                                LargeChange="0.1"
                                                Value="{Binding RenderOverlayOpacity, Mode=TwoWay}" />
                                        <TextBlock Text="{Binding RenderOverlayOpacity, StringFormat='{}{0:0.00}'}"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"
                                                   Width="60"
                                                   FontSize="16"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                        <TextBlock Text="Disable VSync" Foreground="White" VerticalAlignment="Center" FontSize="18" Width="220"/>
                                        <ToggleSwitch IsChecked="{Binding DisableVSync, Mode=TwoWay}" />
                                    </StackPanel>

                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                            <TextBlock Text="Low-latency capture" Foreground="White" VerticalAlignment="Center" FontSize="18" Width="220"/>
                                            <ToggleSwitch IsChecked="{Binding LowLatencyCapture, Mode=TwoWay}"
                                                          ToolTip.Tip="Smaller WGC frame pool and presents on the capture thread. Restart capture (relaunch game) to apply."/>
                                        </StackPanel>
                                        <TextBlock Text="Reduces capture delay; turn off if you see a gray portal or other capture glitches."
                                                   Foreground="#AAAAAA"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="560" />
                                    </StackPanel>

                                    <StackPanel Spacing="8">
                                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                            <TextBlock Text="Frame generation" Foreground="White" VerticalAlignment="Center" FontSize="18" Width="220"/>
                                            <ComboBox MinWidth="320"
                                                      SelectedIndex="{Binding FrameGenerationModeIndex, Mode=TwoWay}"
                                                      ToolTip.Tip="Affects only the Lacrima capture/portal window—not the emulator's own window. Software 120 Hz needs a high-refresh display and VSync disabled.">
                                                <ComboBoxItem Content="Off" />
                                                <ComboBoxItem Content="Software 120 Hz (portal only)" />
                                                <ComboBoxItem Content="AMD AFMF (driver / portal)" />
                                            </ComboBox>
                                        </StackPanel>
                                        <TextBlock Text="Only smooths the capture portal. The emulator game window is unchanged. With stats overlay on, present FPS should rise when Software 120 Hz is working (synth count in status)."
                                                   Foreground="#AAAAAA"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="560" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                        <TextBlock Text="Show Stats Overlay" Foreground="White" VerticalAlignment="Center" FontSize="18" Width="220"/>
                                        <ToggleSwitch IsChecked="{Binding ShowStatisticsOverlay, Mode=TwoWay}" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                        <TextBlock Text="Show Frametime Graph" Foreground="White" VerticalAlignment="Center" FontSize="18" Width="220"/>
                                        <ToggleSwitch IsChecked="{Binding ShowFrametimeGraph, Mode=TwoWay}" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                        <TextBlock Text="Show GPU Info" Foreground="White" VerticalAlignment="Center" FontSize="18" Width="220"/>
                                        <ToggleSwitch IsChecked="{Binding ShowDetailedGpuInfo, Mode=TwoWay}" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                        <TextBlock Text="Color Tint" Foreground="White" VerticalAlignment="Center" FontSize="18" Width="220"/>
                                        <ColorPicker Width="120" Height="40" Color="{Binding ElementName=RootView, Path=PortalCaptureTint, Mode=TwoWay}"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                        <TextBlock Text="Shader File" Foreground="White" VerticalAlignment="Center" FontSize="18" Width="220"/>
                                        <ComboBox MinWidth="320"
                                                  HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding ShaderFileItems}"
                                                  SelectedItem="{Binding SelectedShaderFileItem, Mode=TwoWay}">
                                            <Interaction.Behaviors>
                                                <controlBehaviors:ComboBoxPopupScaler/>
                                            </Interaction.Behaviors>
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Name}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="Handler">
                            <ScrollViewer>
                                <StackPanel Margin="0,12,0,0" Spacing="12">
                                    <TextBlock Text="Current Emulator Handler" Foreground="White" FontSize="20" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding CurrentEmulatorHandler.DisplayName}" Foreground="#E0E0E0" FontSize="18" />
                                    <TextBlock Text="{Binding CurrentEmulatorHandler.SectionTitle}" Foreground="#B0B0B0" FontSize="16" />
                                    <TextBlock Text="Launcher Path" Foreground="White" FontSize="18" Margin="0,12,0,0" />
                                    <TextBlock Text="{Binding CurrentEmulatorHandler.LauncherDisplayPath}" TextWrapping="Wrap" Foreground="#D0D0D0" FontSize="16" />

                                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,12,0,0">
                                        <Button Content="Browse Launcher"
                                                Command="{Binding CurrentEmulatorHandler.BrowseLauncherCommand}"
                                                Padding="12,8"
                                                Background="#222"
                                                Foreground="White"
                                                BorderBrush="#555"
                                                BorderThickness="1"/>
                                        <Button Content="Clear Launcher"
                                                Command="{Binding CurrentEmulatorHandler.ClearLauncherCommand}"
                                                Padding="12,8"
                                                Background="#222"
                                                Foreground="White"
                                                BorderBrush="#555"
                                                BorderThickness="1"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal"
                                                Spacing="12"
                                                Margin="0,12,0,0"
                                                VerticalAlignment="Center"
                                                IsVisible="{Binding ShowCurrentSectionRetroArchCoreSelection}">
                                        <TextBlock Text="RetroArch Core"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"
                                                   FontSize="18"
                                                   Width="220"/>
                                        <ComboBox MinWidth="260"
                                                  HorizontalAlignment="Stretch"
                                                  ItemsSource="{Binding CurrentSectionRetroArchCores}"
                                                  SelectedItem="{Binding SelectedCurrentSectionRetroArchCore, Mode=TwoWay}">
                                            <Interaction.Behaviors>
                                                <controlBehaviors:ComboBoxPopupScaler/>
                                            </Interaction.Behaviors>
                                        </ComboBox>
                                    </StackPanel>

                                    <Border IsVisible="{Binding ShowCurrentSectionRetroArchUpdateControls}"
                                            Margin="0,14,0,0"
                                            Padding="12"
                                            BorderBrush="#555"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Background="#1A1A1A">
                                        <StackPanel Spacing="10">
                                            <TextBlock Text="RetroArch Update" Foreground="White" FontSize="18" FontWeight="SemiBold"/>

                                            <TextBlock Text="Repository Override (owner/repo or URL)"
                                                       Foreground="#D0D0D0"
                                                       FontSize="14"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBox Text="{Binding CurrentSectionRetroArchRepositoryOverride, Mode=TwoWay}"
                                                         PlaceholderText="https://buildbot.libretro.com/nightly/"
                                                         MinWidth="360"
                                                         HorizontalAlignment="Stretch"/>
                                                <Button Content="Apply"
                                                        Command="{Binding ApplyCurrentSectionRetroArchRepositoryCommand}"
                                                        IsEnabled="{Binding IsCurrentSectionRetroArchRepositoryDirty}"
                                                        Padding="12,8"
                                                        Background="#222"
                                                        Foreground="White"
                                                        BorderBrush="#555"
                                                        BorderThickness="1"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                <TextBlock Text="Current Version" Foreground="White" FontSize="16" Width="220"/>
                                                <TextBlock Text="{Binding CurrentSectionRetroArchCurrentVersion, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                                           Foreground="#E0E0E0"
                                                           FontSize="16"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                <TextBlock Text="Latest Version" Foreground="White" FontSize="16" Width="220"/>
                                                <TextBlock Text="{Binding CurrentSectionRetroArchLatestVersion, FallbackValue=Unavailable, TargetNullValue=Unavailable}"
                                                           Foreground="#E0E0E0"
                                                           FontSize="16"/>
                                            </StackPanel>

                                            <TextBlock Text="A new RetroArch version is available."
                                                       IsVisible="{Binding IsCurrentSectionRetroArchUpdateAvailable}"
                                                       Foreground="#FFD166"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"/>

                                            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                <TextBlock Text="Target Version" Foreground="White" FontSize="16" Width="220"/>
                                                <ComboBox MinWidth="260"
                                                          HorizontalAlignment="Stretch"
                                                          ItemsSource="{Binding CurrentSectionRetroArchAvailableVersions}"
                                                          SelectedItem="{Binding SelectedCurrentSectionRetroArchVersion, Mode=TwoWay}">
                                                    <Interaction.Behaviors>
                                                        <controlBehaviors:ComboBoxPopupScaler/>
                                                    </Interaction.Behaviors>
                                                </ComboBox>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                <TextBlock Text="Include Cores" Foreground="White" FontSize="16" Width="220"/>
                                                <ToggleSwitch IsChecked="{Binding IncludeCurrentSectionRetroArchCores, Mode=TwoWay}" />
                                            </StackPanel>

                                            <TextBlock Text="{Binding CurrentSectionRetroArchStatus}"
                                                       Foreground="#C8C8C8"
                                                       TextWrapping="Wrap"/>

                                            <StackPanel IsVisible="{Binding IsCurrentSectionRetroArchDownloading}" Spacing="4">
                                                <TextBlock Text="Downloading and applying RetroArch update..."
                                                           Foreground="#E0E0E0"
                                                           FontSize="14"/>
                                                <ProgressBar Minimum="0"
                                                             Maximum="100"
                                                             Value="{Binding CurrentSectionRetroArchDownloadProgress}"
                                                             IsIndeterminate="False"
                                                             Height="8"/>
                                            </StackPanel>

                                            <TextBlock Text="{Binding CurrentSectionRetroArchEmulatorPath, StringFormat='Emulator Folder: {0}'}"
                                                       Foreground="#AFAFAF"
                                                       FontSize="13"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding CurrentSectionRetroArchUpdatePath, StringFormat='Update Temp (Emu_Update): {0}'}"
                                                       Foreground="#AFAFAF"
                                                       FontSize="13"
                                                       TextWrapping="Wrap"/>

                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <Button Content="Refresh Versions"
                                                        Command="{Binding RefreshCurrentSectionRetroArchInfoCommand}"
                                                        Padding="12,8"
                                                        Background="#222"
                                                        Foreground="White"
                                                        BorderBrush="#555"
                                                        BorderThickness="1"/>
                                                <Button Content="Download / Update RetroArch"
                                                        Command="{Binding DownloadOrUpdateCurrentSectionRetroArchCommand}"
                                                        Padding="12,8"
                                                        Background="#222"
                                                        Foreground="White"
                                                        BorderBrush="#555"
                                                        BorderThickness="1"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                     <Border IsVisible="{Binding ShowCurrentSectionEdenUpdateControls}"
                                             Margin="0,14,0,0"
                                             Padding="12"
                                             BorderBrush="#555"
                                             BorderThickness="1"
                                             CornerRadius="8"
                                             Background="#1A1A1A">
                                         <StackPanel Spacing="10">
                                             <TextBlock Text="Eden Update" Foreground="White" FontSize="18" FontWeight="SemiBold"/>

                                             <TextBlock Text="Repository Override (owner/repo or GitHub URL)"
                                                        Foreground="#D0D0D0"
                                                        FontSize="14"/>
                                             <StackPanel Orientation="Horizontal" Spacing="8">
                                                 <TextBox Text="{Binding CurrentSectionEdenRepositoryOverride, Mode=TwoWay}"
                                                           PlaceholderText="https://git.eden-emu.dev/eden-emu/eden"
                                                          MinWidth="360"
                                                          HorizontalAlignment="Stretch"/>
                                                 <Button Content="Apply"
                                                         Command="{Binding ApplyCurrentSectionEdenRepositoryCommand}"
                                                         IsEnabled="{Binding IsCurrentSectionEdenRepositoryDirty}"
                                                         Padding="12,8"
                                                         Background="#222"
                                                         Foreground="White"
                                                         BorderBrush="#555"
                                                         BorderThickness="1"/>
                                             </StackPanel>

                                             <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                 <TextBlock Text="Current Version" Foreground="White" FontSize="16" Width="220"/>
                                                 <TextBlock Text="{Binding CurrentSectionEdenCurrentVersion, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                                            Foreground="#E0E0E0"
                                                            FontSize="16"/>
                                             </StackPanel>

                                             <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                 <TextBlock Text="Latest Version" Foreground="White" FontSize="16" Width="220"/>
                                                 <TextBlock Text="{Binding CurrentSectionEdenLatestVersion, FallbackValue=Unavailable, TargetNullValue=Unavailable}"
                                                            Foreground="#E0E0E0"
                                                            FontSize="16"/>
                                             </StackPanel>

                                             <TextBlock Text="A new Eden version is available."
                                                        IsVisible="{Binding IsCurrentSectionEdenUpdateAvailable}"
                                                        Foreground="#FFD166"
                                                        FontSize="15"
                                                        FontWeight="SemiBold"/>

                                             <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                 <TextBlock Text="Target Version" Foreground="White" FontSize="16" Width="220"/>
                                                 <ComboBox MinWidth="260"
                                                           HorizontalAlignment="Stretch"
                                                           ItemsSource="{Binding CurrentSectionEdenAvailableVersions}"
                                                           SelectedItem="{Binding SelectedCurrentSectionEdenVersion, Mode=TwoWay}">
                                                     <Interaction.Behaviors>
                                                         <controlBehaviors:ComboBoxPopupScaler/>
                                                     </Interaction.Behaviors>
                                                 </ComboBox>
                                             </StackPanel>

                                             <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                 <TextBlock Text="Include Pre-releases" Foreground="White" FontSize="16" Width="220"/>
                                                 <ToggleSwitch IsChecked="{Binding IncludeCurrentSectionEdenPrereleases, Mode=TwoWay}" />
                                             </StackPanel>

                                             <TextBlock Text="{Binding CurrentSectionEdenStatus}"
                                                        Foreground="#C8C8C8"
                                                        TextWrapping="Wrap"/>

                                             <StackPanel IsVisible="{Binding IsCurrentSectionEdenDownloading}" Spacing="4">
                                                 <TextBlock Text="Downloading and applying Eden update..."
                                                            Foreground="#E0E0E0"
                                                            FontSize="14"/>
                                                 <ProgressBar Minimum="0"
                                                              Maximum="100"
                                                              Value="{Binding CurrentSectionEdenDownloadProgress}"
                                                              IsIndeterminate="False"
                                                              Height="8"/>
                                             </StackPanel>

                                             <TextBlock Text="{Binding CurrentSectionEdenEmulatorPath, StringFormat='Emulator Folder: {0}'}"
                                                        Foreground="#AFAFAF"
                                                        FontSize="13"
                                                        TextWrapping="Wrap"/>
                                             <TextBlock Text="{Binding CurrentSectionEdenUpdatePath, StringFormat='Update Temp (Emu_Update): {0}'}"
                                                        Foreground="#AFAFAF"
                                                        FontSize="13"
                                                        TextWrapping="Wrap"/>

                                             <StackPanel Orientation="Horizontal" Spacing="10">
                                                 <Button Content="Refresh Versions"
                                                         Command="{Binding RefreshCurrentSectionEdenInfoCommand}"
                                                         Padding="12,8"
                                                         Background="#222"
                                                         Foreground="White"
                                                         BorderBrush="#555"
                                                         BorderThickness="1"/>
                                                 <Button Content="Download / Update Eden"
                                                         Command="{Binding DownloadOrUpdateCurrentSectionEdenCommand}"
                                                         Padding="12,8"
                                                         Background="#222"
                                                         Foreground="White"
                                                         BorderBrush="#555"
                                                         BorderThickness="1"/>
                                             </StackPanel>
                                         </StackPanel>
                                     </Border>

                                     <Border IsVisible="{Binding ShowCurrentSectionShadPs4UpdateControls}"
                                             Margin="0,14,0,0"
                                             Padding="12"
                                             BorderBrush="#555"
                                             BorderThickness="1"
                                             CornerRadius="8"
                                             Background="#1A1A1A">
                                         <StackPanel Spacing="10">
                                             <TextBlock Text="shadPS4 Update" Foreground="White" FontSize="18" FontWeight="SemiBold"/>

                                             <TextBlock Text="Repository Override (owner/repo or URL)"
                                                        Foreground="#D0D0D0"
                                                        FontSize="14"/>
                                             <StackPanel Orientation="Horizontal" Spacing="8">
                                                 <TextBox Text="{Binding CurrentSectionShadPs4RepositoryOverride, Mode=TwoWay}"
                                                           PlaceholderText="https://github.com/shadps4-emu/shadPS4"
                                                          MinWidth="360"
                                                          HorizontalAlignment="Stretch"/>
                                                 <Button Content="Apply"
                                                         Command="{Binding ApplyCurrentSectionShadPs4RepositoryCommand}"
                                                         IsEnabled="{Binding IsCurrentSectionShadPs4RepositoryDirty}"
                                                         Padding="12,8"
                                                         Background="#222"
                                                         Foreground="White"
                                                         BorderBrush="#555"
                                                         BorderThickness="1"/>
                                             </StackPanel>

                                             <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                 <TextBlock Text="Current Version" Foreground="White" FontSize="16" Width="220"/>
                                                 <TextBlock Text="{Binding CurrentSectionShadPs4CurrentVersion, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                                            Foreground="#E0E0E0"
                                                            FontSize="16"/>
                                             </StackPanel>

                                             <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                 <TextBlock Text="Latest Version" Foreground="White" FontSize="16" Width="220"/>
                                                 <TextBlock Text="{Binding CurrentSectionShadPs4LatestVersion, FallbackValue=Unavailable, TargetNullValue=Unavailable}"
                                                            Foreground="#E0E0E0"
                                                            FontSize="16"/>
                                             </StackPanel>

                                             <TextBlock Text="A new shadPS4 version is available."
                                                        IsVisible="{Binding IsCurrentSectionShadPs4UpdateAvailable}"
                                                        Foreground="#FFD166"
                                                        FontSize="15"
                                                        FontWeight="SemiBold"/>

                                             <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                 <TextBlock Text="Target Version" Foreground="White" FontSize="16" Width="220"/>
                                                 <ComboBox MinWidth="260"
                                                           HorizontalAlignment="Stretch"
                                                           ItemsSource="{Binding CurrentSectionShadPs4AvailableVersions}"
                                                           SelectedItem="{Binding SelectedCurrentSectionShadPs4Version, Mode=TwoWay}">
                                                     <Interaction.Behaviors>
                                                         <controlBehaviors:ComboBoxPopupScaler/>
                                                     </Interaction.Behaviors>
                                                 </ComboBox>
                                             </StackPanel>

                                             <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                 <TextBlock Text="Include Pre-releases" Foreground="White" FontSize="16" Width="220"/>
                                                 <ToggleSwitch IsChecked="{Binding IncludeCurrentSectionShadPs4Prereleases, Mode=TwoWay}" />
                                             </StackPanel>

                                             <TextBlock Text="{Binding CurrentSectionShadPs4Status}"
                                                        Foreground="#C8C8C8"
                                                        TextWrapping="Wrap"/>

                                             <StackPanel IsVisible="{Binding IsCurrentSectionShadPs4Downloading}" Spacing="4">
                                                 <TextBlock Text="Downloading and applying shadPS4 update..."
                                                            Foreground="#E0E0E0"
                                                            FontSize="14"/>
                                                 <ProgressBar Minimum="0"
                                                              Maximum="100"
                                                              Value="{Binding CurrentSectionShadPs4DownloadProgress}"
                                                              IsIndeterminate="False"
                                                              Height="8"/>
                                             </StackPanel>

                                             <TextBlock Text="{Binding CurrentSectionShadPs4EmulatorPath, StringFormat='Emulator Folder: {0}'}"
                                                        Foreground="#AFAFAF"
                                                        FontSize="13"
                                                        TextWrapping="Wrap"/>
                                             <TextBlock Text="{Binding CurrentSectionShadPs4UpdatePath, StringFormat='Update Temp (Emu_Update): {0}'}"
                                                        Foreground="#AFAFAF"
                                                        FontSize="13"
                                                        TextWrapping="Wrap"/>

                                             <StackPanel Orientation="Horizontal" Spacing="10">
                                                 <Button Content="Refresh Versions"
                                                         Command="{Binding RefreshCurrentSectionShadPs4InfoCommand}"
                                                         Padding="12,8"
                                                         Background="#222"
                                                         Foreground="White"
                                                         BorderBrush="#555"
                                                         BorderThickness="1"/>
                                                 <Button Content="Download / Update shadPS4"
                                                         Command="{Binding DownloadOrUpdateCurrentSectionShadPs4Command}"
                                                         Padding="12,8"
                                                         Background="#222"
                                                         Foreground="White"
                                                         BorderBrush="#555"
                                                         BorderThickness="1"/>
                                             </StackPanel>
                                         </StackPanel>
                                     </Border>

                                      <Border IsVisible="{Binding ShowCurrentSectionXeniaUpdateControls}"
                                              Margin="0,14,0,0"
                                              Padding="12"
                                              BorderBrush="#555"
                                              BorderThickness="1"
                                              CornerRadius="8"
                                              Background="#1A1A1A">
                                          <StackPanel Spacing="10">
                                              <TextBlock Text="Xenia Canary Update" Foreground="White" FontSize="18" FontWeight="SemiBold"/>

                                              <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                  <TextBlock Text="Current Version" Foreground="White" FontSize="16" Width="220"/>
                                                  <TextBlock Text="{Binding CurrentSectionXeniaCurrentVersion, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                                             Foreground="#E0E0E0"
                                                             FontSize="16"/>
                                              </StackPanel>

                                              <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                  <TextBlock Text="Latest Version" Foreground="White" FontSize="16" Width="220"/>
                                                  <TextBlock Text="{Binding CurrentSectionXeniaLatestVersion, FallbackValue=Unavailable, TargetNullValue=Unavailable}"
                                                             Foreground="#E0E0E0"
                                                             FontSize="16"/>
                                              </StackPanel>

                                              <TextBlock Text="A new Xenia Canary version is available."
                                                         IsVisible="{Binding IsCurrentSectionXeniaUpdateAvailable}"
                                                         Foreground="#FFD166"
                                                         FontSize="15"
                                                         FontWeight="SemiBold"/>

                                              <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                  <TextBlock Text="Target Version" Foreground="White" FontSize="16" Width="220"/>
                                                  <ComboBox MinWidth="260"
                                                            HorizontalAlignment="Stretch"
                                                            ItemsSource="{Binding CurrentSectionXeniaAvailableVersions}"
                                                            SelectedItem="{Binding SelectedCurrentSectionXeniaVersion, Mode=TwoWay}">
                                                      <Interaction.Behaviors>
                                                          <controlBehaviors:ComboBoxPopupScaler/>
                                                      </Interaction.Behaviors>
                                                  </ComboBox>
                                              </StackPanel>

                                              <TextBlock Text="{Binding CurrentSectionXeniaStatus}"
                                                         Foreground="#C8C8C8"
                                                         TextWrapping="Wrap"/>

                                              <StackPanel IsVisible="{Binding IsCurrentSectionXeniaDownloading}" Spacing="4">
                                                  <TextBlock Text="Downloading and applying Xenia Canary update..."
                                                             Foreground="#E0E0E0"
                                                             FontSize="14"/>
                                                  <ProgressBar Minimum="0"
                                                               Maximum="100"
                                                               Value="{Binding CurrentSectionXeniaDownloadProgress}"
                                                               IsIndeterminate="False"
                                                               Height="8"/>
                                              </StackPanel>

                                              <TextBlock Text="{Binding CurrentSectionXeniaEmulatorPath, StringFormat='Emulator Folder: {0}'}"
                                                         Foreground="#AFAFAF"
                                                         FontSize="13"
                                                         TextWrapping="Wrap"/>
                                              <TextBlock Text="{Binding CurrentSectionXeniaUpdatePath, StringFormat='Update Temp (Emu_Update): {0}'}"
                                                         Foreground="#AFAFAF"
                                                         FontSize="13"
                                                         TextWrapping="Wrap"/>

                                              <StackPanel Orientation="Horizontal" Spacing="10">
                                                  <Button Content="Refresh Versions"
                                                          Command="{Binding RefreshCurrentSectionXeniaInfoCommand}"
                                                          Padding="12,8"
                                                          Background="#222"
                                                          Foreground="White"
                                                          BorderBrush="#555"
                                                          BorderThickness="1"/>
                                                  <Button Content="Download / Update Xenia Canary"
                                                          Command="{Binding DownloadOrUpdateCurrentSectionXeniaCommand}"
                                                          Padding="12,8"
                                                          Background="#222"
                                                          Foreground="White"
                                                          BorderBrush="#555"
                                                          BorderThickness="1"/>
                                              </StackPanel>
                                          </StackPanel>
                                      </Border>

                                       <Border IsVisible="{Binding ShowCurrentSectionPcsx2UpdateControls}"
                                              Margin="0,14,0,0"
                                              Padding="12"
                                              BorderBrush="#555"
                                              BorderThickness="1"
                                              CornerRadius="8"
                                              Background="#1A1A1A">
                                           <StackPanel Spacing="10">
                                               <TextBlock Text="PCSX2 Update" Foreground="White" FontSize="18" FontWeight="SemiBold"/>

                                               <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                   <TextBlock Text="Current Version" Foreground="White" FontSize="16" Width="220"/>
                                                   <TextBlock Text="{Binding CurrentSectionPcsx2CurrentVersion, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                                              Foreground="#E0E0E0"
                                                              FontSize="16"/>
                                               </StackPanel>

                                               <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                   <TextBlock Text="Latest Version" Foreground="White" FontSize="16" Width="220"/>
                                                   <TextBlock Text="{Binding CurrentSectionPcsx2LatestVersion, FallbackValue=Unavailable, TargetNullValue=Unavailable}"
                                                              Foreground="#E0E0E0"
                                                              FontSize="16"/>
                                               </StackPanel>

                                               <TextBlock Text="A new PCSX2 version is available."
                                                          IsVisible="{Binding IsCurrentSectionPcsx2UpdateAvailable}"
                                                          Foreground="#FFD166"
                                                          FontSize="15"
                                                          FontWeight="SemiBold"/>

                                               <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                   <TextBlock Text="Target Version" Foreground="White" FontSize="16" Width="220"/>
                                                   <ComboBox MinWidth="260"
                                                             HorizontalAlignment="Stretch"
                                                             ItemsSource="{Binding CurrentSectionPcsx2AvailableVersions}"
                                                             SelectedItem="{Binding SelectedCurrentSectionPcsx2Version, Mode=TwoWay}">
                                                       <Interaction.Behaviors>
                                                           <controlBehaviors:ComboBoxPopupScaler/>
                                                       </Interaction.Behaviors>
                                                   </ComboBox>
                                               </StackPanel>

                                                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                    <TextBlock Text="Include Pre-releases" Foreground="White" FontSize="16" Width="220"/>
                                                    <ToggleSwitch IsChecked="{Binding IncludeCurrentSectionPcsx2Prereleases, Mode=TwoWay}" />
                                                </StackPanel>

                                               <TextBlock Text="{Binding CurrentSectionPcsx2Status}"
                                                          Foreground="#C8C8C8"
                                                          TextWrapping="Wrap"/>

                                               <StackPanel IsVisible="{Binding IsCurrentSectionPcsx2Downloading}" Spacing="4">
                                                   <TextBlock Text="Downloading and applying PCSX2 update..."
                                                              Foreground="#E0E0E0"
                                                              FontSize="14"/>
                                                   <ProgressBar Minimum="0"
                                                                Maximum="100"
                                                                Value="{Binding CurrentSectionPcsx2DownloadProgress}"
                                                                IsIndeterminate="False"
                                                                Height="8"/>
                                               </StackPanel>

                                               <TextBlock Text="{Binding CurrentSectionPcsx2EmulatorPath, StringFormat='Emulator Folder: {0}'}"
                                                          Foreground="#AFAFAF"
                                                          FontSize="13"
                                                          TextWrapping="Wrap"/>
                                               <TextBlock Text="{Binding CurrentSectionPcsx2UpdatePath, StringFormat='Update Temp (Emu_Update): {0}'}"
                                                          Foreground="#AFAFAF"
                                                          FontSize="13"
                                                          TextWrapping="Wrap"/>

                                               <StackPanel Orientation="Horizontal" Spacing="10">
                                                   <Button Content="Refresh Versions"
                                                           Command="{Binding RefreshCurrentSectionPcsx2InfoCommand}"
                                                           Padding="12,8"
                                                           Background="#222"
                                                           Foreground="White"
                                                           BorderBrush="#555"
                                                           BorderThickness="1"/>
                                                   <Button Content="Download / Update PCSX2"
                                                           Command="{Binding DownloadOrUpdateCurrentSectionPcsx2Command}"
                                                           Padding="12,8"
                                                           Background="#222"
                                                           Foreground="White"
                                                           BorderBrush="#555"
                                                           BorderThickness="1"/>
                                               </StackPanel>
                                           </StackPanel>
                                       </Border>

                                       <Border IsVisible="{Binding ShowCurrentSectionRpcs3UpdateControls}"
                                              Margin="0,14,0,0"
                                              Padding="12"
                                              BorderBrush="#555"
                                              BorderThickness="1"
                                              CornerRadius="8"
                                              Background="#1A1A1A">
                                           <StackPanel Spacing="10">
                                               <TextBlock Text="RPCS3 Update" Foreground="White" FontSize="18" FontWeight="SemiBold"/>

                                               <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                   <TextBlock Text="Current Version" Foreground="White" FontSize="16" Width="220"/>
                                                   <TextBlock Text="{Binding CurrentSectionRpcs3CurrentVersion, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                                              Foreground="#E0E0E0"
                                                              FontSize="16"/>
                                               </StackPanel>

                                               <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                   <TextBlock Text="Latest Version" Foreground="White" FontSize="16" Width="220"/>
                                                   <TextBlock Text="{Binding CurrentSectionRpcs3LatestVersion, FallbackValue=Unavailable, TargetNullValue=Unavailable}"
                                                              Foreground="#E0E0E0"
                                                              FontSize="16"/>
                                               </StackPanel>

                                               <TextBlock Text="A new RPCS3 version is available."
                                                          IsVisible="{Binding IsCurrentSectionRpcs3UpdateAvailable}"
                                                          Foreground="#FFD166"
                                                          FontSize="15"
                                                          FontWeight="SemiBold"/>

                                               <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                   <TextBlock Text="Target Version" Foreground="White" FontSize="16" Width="220"/>
                                                   <ComboBox MinWidth="260"
                                                             HorizontalAlignment="Stretch"
                                                             ItemsSource="{Binding CurrentSectionRpcs3AvailableVersions}"
                                                             SelectedItem="{Binding SelectedCurrentSectionRpcs3Version, Mode=TwoWay}">
                                                       <Interaction.Behaviors>
                                                           <controlBehaviors:ComboBoxPopupScaler/>
                                                       </Interaction.Behaviors>
                                                   </ComboBox>
                                               </StackPanel>

                                               <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                   <TextBlock Text="Include Nightly Builds" Foreground="White" FontSize="16" Width="220"/>
                                                   <ToggleSwitch IsChecked="{Binding IncludeCurrentSectionRpcs3Prereleases, Mode=TwoWay}" />
                                               </StackPanel>

                                               <TextBlock Text="{Binding CurrentSectionRpcs3Status}"
                                                          Foreground="#C8C8C8"
                                                          TextWrapping="Wrap"/>

                                               <StackPanel IsVisible="{Binding IsCurrentSectionRpcs3Downloading}" Spacing="4">
                                                   <TextBlock Text="Downloading and applying RPCS3 update..."
                                                              Foreground="#E0E0E0"
                                                              FontSize="14"/>
                                                   <ProgressBar Minimum="0"
                                                                Maximum="100"
                                                                Value="{Binding CurrentSectionRpcs3DownloadProgress}"
                                                                IsIndeterminate="False"
                                                                Height="8"/>
                                               </StackPanel>

                                               <TextBlock Text="{Binding CurrentSectionRpcs3EmulatorPath, StringFormat='Emulator Folder: {0}'}"
                                                          Foreground="#AFAFAF"
                                                          FontSize="13"
                                                          TextWrapping="Wrap"/>
                                               <TextBlock Text="{Binding CurrentSectionRpcs3UpdatePath, StringFormat='Update Temp (Emu_Update): {0}'}"
                                                          Foreground="#AFAFAF"
                                                          FontSize="13"
                                                          TextWrapping="Wrap"/>

                                               <StackPanel Orientation="Horizontal" Spacing="10">
                                                   <Button Content="Refresh Versions"
                                                           Command="{Binding RefreshCurrentSectionRpcs3InfoCommand}"
                                                           Padding="12,8"
                                                           Background="#222"
                                                           Foreground="White"
                                                           BorderBrush="#555"
                                                           BorderThickness="1"/>
                                                   <Button Content="Download / Update RPCS3"
                                                           Command="{Binding DownloadOrUpdateCurrentSectionRpcs3Command}"
                                                           Padding="12,8"
                                                           Background="#222"
                                                           Foreground="White"
                                                           BorderBrush="#555"
                                                           BorderThickness="1"/>
                                               </StackPanel>
                                           </StackPanel>
                                       </Border>

                                       <Border IsVisible="{Binding ShowCurrentSectionDolphinUpdateControls}"
                                              Margin="0,14,0,0"
                                              Padding="12"
                                              BorderBrush="#555"
                                              BorderThickness="1"
                                              CornerRadius="8"
                                              Background="#1A1A1A">
                                           <StackPanel Spacing="10">
                                               <TextBlock Text="Dolphin Update" Foreground="White" FontSize="18" FontWeight="SemiBold"/>

                                               <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                   <TextBlock Text="Current Version" Foreground="White" FontSize="16" Width="220"/>
                                                   <TextBlock Text="{Binding CurrentSectionDolphinCurrentVersion, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                                              Foreground="#E0E0E0"
                                                              FontSize="16"/>
                                               </StackPanel>

                                               <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                   <TextBlock Text="Latest Version" Foreground="White" FontSize="16" Width="220"/>
                                                   <TextBlock Text="{Binding CurrentSectionDolphinLatestVersion, FallbackValue=Unavailable, TargetNullValue=Unavailable}"
                                                              Foreground="#E0E0E0"
                                                              FontSize="16"/>
                                               </StackPanel>

                                               <TextBlock Text="A new Dolphin version is available."
                                                          IsVisible="{Binding IsCurrentSectionDolphinUpdateAvailable}"
                                                          Foreground="#FFD166"
                                                          FontSize="15"
                                                          FontWeight="SemiBold"/>

                                               <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                   <TextBlock Text="Target Version" Foreground="White" FontSize="16" Width="220"/>
                                                   <ComboBox MinWidth="260"
                                                             HorizontalAlignment="Stretch"
                                                             ItemsSource="{Binding CurrentSectionDolphinAvailableVersions}"
                                                             SelectedItem="{Binding SelectedCurrentSectionDolphinVersion, Mode=TwoWay}">
                                                       <Interaction.Behaviors>
                                                           <controlBehaviors:ComboBoxPopupScaler/>
                                                       </Interaction.Behaviors>
                                                   </ComboBox>
                                               </StackPanel>

                                               <TextBlock Text="{Binding CurrentSectionDolphinStatus}"
                                                          Foreground="#C8C8C8"
                                                          TextWrapping="Wrap"/>

                                               <StackPanel IsVisible="{Binding IsCurrentSectionDolphinDownloading}" Spacing="4">
                                                   <TextBlock Text="Downloading and applying Dolphin update..."
                                                              Foreground="#E0E0E0"
                                                              FontSize="14"/>
                                                   <ProgressBar Minimum="0"
                                                                Maximum="100"
                                                                Value="{Binding CurrentSectionDolphinDownloadProgress}"
                                                                IsIndeterminate="False"
                                                                Height="8"/>
                                               </StackPanel>

                                               <TextBlock Text="{Binding CurrentSectionDolphinEmulatorPath, StringFormat='Emulator Folder: {0}'}"
                                                          Foreground="#AFAFAF"
                                                          FontSize="13"
                                                          TextWrapping="Wrap"/>
                                               <TextBlock Text="{Binding CurrentSectionDolphinUpdatePath, StringFormat='Update Temp (Emu_Update): {0}'}"
                                                          Foreground="#AFAFAF"
                                                          FontSize="13"
                                                          TextWrapping="Wrap"/>

                                               <StackPanel Orientation="Horizontal" Spacing="10">
                                                   <Button Content="Refresh Versions"
                                                           Command="{Binding RefreshCurrentSectionDolphinInfoCommand}"
                                                           Padding="12,8"
                                                           Background="#222"
                                                           Foreground="White"
                                                           BorderBrush="#555"
                                                           BorderThickness="1"/>
                                                   <Button Content="Download / Update Dolphin"
                                                           Command="{Binding DownloadOrUpdateCurrentSectionDolphinCommand}"
                                                           Padding="12,8"
                                                           Background="#222"
                                                           Foreground="White"
                                                           BorderBrush="#555"
                                                           BorderThickness="1"/>
                                               </StackPanel>
                                           </StackPanel>
                                       </Border>

                                        <Border IsVisible="{Binding ShowCurrentSectionFlycastUpdateControls}"
                                               Margin="0,14,0,0"
                                               Padding="12"
                                               BorderBrush="#555"
                                               BorderThickness="1"
                                               CornerRadius="8"
                                               Background="#1A1A1A">
                                            <StackPanel Spacing="10">
                                                <TextBlock Text="Flycast Update" Foreground="White" FontSize="18" FontWeight="SemiBold"/>

                                                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                    <TextBlock Text="Current Version" Foreground="White" FontSize="16" Width="220"/>
                                                    <TextBlock Text="{Binding CurrentSectionFlycastCurrentVersion, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                                               Foreground="#E0E0E0"
                                                               FontSize="16"/>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                    <TextBlock Text="Latest Version" Foreground="White" FontSize="16" Width="220"/>
                                                    <TextBlock Text="{Binding CurrentSectionFlycastLatestVersion, FallbackValue=Unavailable, TargetNullValue=Unavailable}"
                                                               Foreground="#E0E0E0"
                                                               FontSize="16"/>
                                                </StackPanel>

                                                <TextBlock Text="A new Flycast version is available."
                                                           IsVisible="{Binding IsCurrentSectionFlycastUpdateAvailable}"
                                                           Foreground="#FFD166"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"/>

                                                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                    <TextBlock Text="Target Version" Foreground="White" FontSize="16" Width="220"/>
                                                    <ComboBox MinWidth="260"
                                                              HorizontalAlignment="Stretch"
                                                              ItemsSource="{Binding CurrentSectionFlycastAvailableVersions}"
                                                              SelectedItem="{Binding SelectedCurrentSectionFlycastVersion, Mode=TwoWay}">
                                                        <Interaction.Behaviors>
                                                            <controlBehaviors:ComboBoxPopupScaler/>
                                                        </Interaction.Behaviors>
                                                    </ComboBox>
                                                </StackPanel>

                                                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                    <TextBlock Text="Include Nightly Builds" Foreground="White" FontSize="16" Width="220"/>
                                                    <ToggleSwitch IsChecked="{Binding IncludeCurrentSectionFlycastNightlies, Mode=TwoWay}" />
                                                </StackPanel>

                                                <TextBlock Text="{Binding CurrentSectionFlycastStatus}"
                                                           Foreground="#C8C8C8"
                                                           TextWrapping="Wrap"/>

                                                <StackPanel IsVisible="{Binding IsCurrentSectionFlycastDownloading}" Spacing="4">
                                                    <TextBlock Text="Downloading and applying Flycast update..."
                                                               Foreground="#E0E0E0"
                                                               FontSize="14"/>
                                                    <ProgressBar Minimum="0"
                                                                 Maximum="100"
                                                                 Value="{Binding CurrentSectionFlycastDownloadProgress}"
                                                                 IsIndeterminate="False"
                                                                 Height="8"/>
                                                </StackPanel>

                                                <TextBlock Text="{Binding CurrentSectionFlycastEmulatorPath, StringFormat='Emulator Folder: {0}'}"
                                                           Foreground="#AFAFAF"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding CurrentSectionFlycastUpdatePath, StringFormat='Update Temp (Emu_Update): {0}'}"
                                                           Foreground="#AFAFAF"
                                                           FontSize="13"
                                                           TextWrapping="Wrap"/>

                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <Button Content="Refresh Versions"
                                                            Command="{Binding RefreshCurrentSectionFlycastInfoCommand}"
                                                            Padding="12,8"
                                                            Background="#222"
                                                            Foreground="White"
                                                            BorderBrush="#555"
                                                            BorderThickness="1"/>
                                                    <Button Content="Download / Update Flycast"
                                                            Command="{Binding DownloadOrUpdateCurrentSectionFlycastCommand}"
                                                            Padding="12,8"
                                                            Background="#222"
                                                            Foreground="White"
                                                            BorderBrush="#555"
                                                            BorderThickness="1"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                       <Border IsVisible="{Binding ShowCurrentSectionDuckStationUpdateControls}"
                                              Margin="0,14,0,0"
                                              Padding="12"
                                              BorderBrush="#555"
                                              BorderThickness="1"
                                              CornerRadius="8"
                                              Background="#1A1A1A">
                                           <StackPanel Spacing="10">
                                               <TextBlock Text="DuckStation Update" Foreground="White" FontSize="18" FontWeight="SemiBold"/>

                                               <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                   <TextBlock Text="Current Version" Foreground="White" FontSize="16" Width="220"/>
                                                   <TextBlock Text="{Binding CurrentSectionDuckStationCurrentVersion, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                                              Foreground="#E0E0E0"
                                                              FontSize="16"/>
                                               </StackPanel>

                                               <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                   <TextBlock Text="Latest Version" Foreground="White" FontSize="16" Width="220"/>
                                                   <TextBlock Text="{Binding CurrentSectionDuckStationLatestVersion, FallbackValue=Unavailable, TargetNullValue=Unavailable}"
                                                              Foreground="#E0E0E0"
                                                              FontSize="16"/>
                                               </StackPanel>

                                               <TextBlock Text="A new DuckStation version is available."
                                                          IsVisible="{Binding IsCurrentSectionDuckStationUpdateAvailable}"
                                                          Foreground="#FFD166"
                                                          FontSize="15"
                                                          FontWeight="SemiBold"/>

                                               <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                   <TextBlock Text="Target Version" Foreground="White" FontSize="16" Width="220"/>
                                                   <ComboBox MinWidth="260"
                                                             HorizontalAlignment="Stretch"
                                                             ItemsSource="{Binding CurrentSectionDuckStationAvailableVersions}"
                                                             SelectedItem="{Binding SelectedCurrentSectionDuckStationVersion, Mode=TwoWay}">
                                                       <Interaction.Behaviors>
                                                           <controlBehaviors:ComboBoxPopupScaler/>
                                                       </Interaction.Behaviors>
                                                   </ComboBox>
                                               </StackPanel>

                                               <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                   <TextBlock Text="Include Pre-releases" Foreground="White" FontSize="16" Width="220"/>
                                                   <ToggleSwitch IsChecked="{Binding IncludeCurrentSectionDuckStationPrereleases, Mode=TwoWay}" />
                                               </StackPanel>

                                               <TextBlock Text="{Binding CurrentSectionDuckStationStatus}"
                                                          Foreground="#C8C8C8"
                                                          TextWrapping="Wrap"/>

                                               <StackPanel IsVisible="{Binding IsCurrentSectionDuckStationDownloading}" Spacing="4">
                                                   <TextBlock Text="Downloading and applying DuckStation update..."
                                                              Foreground="#E0E0E0"
                                                              FontSize="14"/>
                                                   <ProgressBar Minimum="0"
                                                                Maximum="100"
                                                                Value="{Binding CurrentSectionDuckStationDownloadProgress}"
                                                                IsIndeterminate="False"
                                                                Height="8"/>
                                               </StackPanel>

                                               <TextBlock Text="{Binding CurrentSectionDuckStationEmulatorPath, StringFormat='Emulator Folder: {0}'}"
                                                          Foreground="#AFAFAF"
                                                          FontSize="13"
                                                          TextWrapping="Wrap"/>
                                               <TextBlock Text="{Binding CurrentSectionDuckStationUpdatePath, StringFormat='Update Temp (Emu_Update): {0}'}"
                                                          Foreground="#AFAFAF"
                                                          FontSize="13"
                                                          TextWrapping="Wrap"/>

                                               <StackPanel Orientation="Horizontal" Spacing="10">
                                                   <Button Content="Refresh Versions"
                                                           Command="{Binding RefreshCurrentSectionDuckStationInfoCommand}"
                                                           Padding="12,8"
                                                           Background="#222"
                                                           Foreground="White"
                                                           BorderBrush="#555"
                                                           BorderThickness="1"/>
                                                   <Button Content="Download / Update DuckStation"
                                                           Command="{Binding DownloadOrUpdateCurrentSectionDuckStationCommand}"
                                                           Padding="12,8"
                                                           Background="#222"
                                                           Foreground="White"
                                                           BorderBrush="#555"
                                                           BorderThickness="1"/>
                                               </StackPanel>
                                           </StackPanel>
                                       </Border>

                                       <Border IsVisible="{Binding ShowCurrentSectionCemuSection}"
                                              Margin="0,14,0,0"
                                              Padding="12"
                                              BorderBrush="#555"
                                              BorderThickness="1"
                                              CornerRadius="8"
                                              Background="#1A1A1A">
                                           <StackPanel Spacing="10">
                                              <TextBlock Text="Cemu Update" Foreground="White" FontSize="18" FontWeight="SemiBold"/>

                                              <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                  <TextBlock Text="Current Version" Foreground="White" FontSize="16" Width="220"/>
                                                  <TextBlock Text="{Binding CurrentSectionCemuCurrentVersion, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                                             Foreground="#E0E0E0"
                                                             FontSize="16"/>
                                              </StackPanel>

                                              <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                  <TextBlock Text="Latest Version" Foreground="White" FontSize="16" Width="220"/>
                                                  <TextBlock Text="{Binding CurrentSectionCemuLatestVersion, FallbackValue=Unavailable, TargetNullValue=Unavailable}"
                                                             Foreground="#E0E0E0"
                                                             FontSize="16"/>
                                              </StackPanel>

                                              <TextBlock Text="A new Cemu version is available."
                                                         IsVisible="{Binding IsCurrentSectionCemuUpdateAvailable}"
                                                         Foreground="#FFD166"
                                                         FontSize="15"
                                                         FontWeight="SemiBold"/>

                                              <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                                  <TextBlock Text="Target Version" Foreground="White" FontSize="16" Width="220"/>
                                                  <ComboBox MinWidth="260"
                                                            HorizontalAlignment="Stretch"
                                                            ItemsSource="{Binding CurrentSectionCemuAvailableVersions}"
                                                            SelectedItem="{Binding SelectedCurrentSectionCemuVersion, Mode=TwoWay}">
                                                      <Interaction.Behaviors>
                                                          <controlBehaviors:ComboBoxPopupScaler/>
                                                      </Interaction.Behaviors>
                                                  </ComboBox>
                                              </StackPanel>

                                              <TextBlock Text="{Binding CurrentSectionCemuStatus}"
                                                         Foreground="#C8C8C8"
                                                         TextWrapping="Wrap"/>

                                              <StackPanel IsVisible="{Binding IsCurrentSectionCemuDownloading}" Spacing="4">
                                                  <TextBlock Text="Downloading and applying Cemu update..."
                                                             Foreground="#E0E0E0"
                                                             FontSize="14"/>
                                                  <ProgressBar Minimum="0"
                                                               Maximum="100"
                                                               Value="{Binding CurrentSectionCemuDownloadProgress}"
                                                               IsIndeterminate="False"
                                                               Height="8"/>
                                              </StackPanel>

                                              <TextBlock Text="{Binding CurrentSectionCemuEmulatorPath, StringFormat='Emulator Folder: {0}'}"
                                                         Foreground="#AFAFAF"
                                                         FontSize="13"
                                                         TextWrapping="Wrap"/>
                                              <TextBlock Text="{Binding CurrentSectionCemuUpdatePath, StringFormat='Update Temp (Emu_Update): {0}'}"
                                                         Foreground="#AFAFAF"
                                                         FontSize="13"
                                                         TextWrapping="Wrap"/>

                                              <StackPanel Orientation="Horizontal" Spacing="10">
                                                  <Button Content="Refresh Versions"
                                                          Command="{Binding RefreshCurrentSectionCemuInfoCommand}"
                                                          Padding="12,8"
                                                          Background="#222"
                                                          Foreground="White"
                                                          BorderBrush="#555"
                                                          BorderThickness="1"/>
                                                  <Button Content="Download / Update Cemu"
                                                          Command="{Binding DownloadOrUpdateCurrentSectionCemuCommand}"
                                                          Padding="12,8"
                                                          Background="#222"
                                                          Foreground="White"
                                                          BorderBrush="#555"
                                                          BorderThickness="1"/>
                                              </StackPanel>
                                           </StackPanel>
                                       </Border>

                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Grid>
            </ScrollViewer>
            </Border>

            <Border x:Name="RetroArchErrorOverlay"
                    Background="#CC000000"
                    BorderBrush="#FFC107"
                    BorderThickness="1"
                    CornerRadius="14"
                    Width="560"
                    MinWidth="520"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,90,20,0"
                    ZIndex="2200"
                    IsVisible="{Binding IsRetroArchErrorOverlayOpen}"
                    Opacity="{Binding IsRetroArchErrorOverlayOpen, Converter={StaticResource BoolToOpacityConverter}}"
                    IsHitTestVisible="{Binding IsRetroArchErrorOverlayOpen}">
                <StackPanel Margin="20" Spacing="16">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Text="RetroArch launch warning"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   VerticalAlignment="Center" />
                        <Button Command="{Binding ToggleRetroArchErrorOverlayCommand}"
                                Width="34"
                                Height="34"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                Foreground="White"
                                Content="✕"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center" />
                    </Grid>
                    <Border Background="#22111111"
                            CornerRadius="10"
                            Padding="14">
                        <ScrollViewer MaxHeight="340"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="12">
                                <TextBlock Text="{Binding RetroArchErrorSummary}"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           FontSize="20"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding RetroArchErrorDetails}"
                                           Foreground="#E0E0E0"
                                           FontSize="15"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <Border x:Name="EmulatorUpdateNoticeOverlay"
                Grid.Row="0"
                Background="#E6000000"
                BorderBrush="DimGray"
                BorderThickness="1"
                CornerRadius="14"
                Width="560"
                MinWidth="520"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,90,20,0"
                ZIndex="2300"
                IsVisible="{Binding IsEmulatorUpdateNoticeOverlayOpen}"
                Opacity="{Binding IsEmulatorUpdateNoticeOverlayOpen, Converter={StaticResource BoolToOpacityConverter}}"
                IsHitTestVisible="{Binding IsEmulatorUpdateNoticeOverlayOpen}">
            <StackPanel Margin="20" Spacing="16">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Emulator update available"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="WhiteSmoke"
                               VerticalAlignment="Center" />
                    <Button Command="{Binding DismissEmulatorUpdateNoticeOverlayCommand}"
                            Width="34"
                            Height="34"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            Foreground="WhiteSmoke"
                            Content="✕"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center" />
                </Grid>
                <Border Background="#171717"
                        BorderBrush="#343434"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{Binding EmulatorUpdateNoticeSummary}"
                                   Foreground="WhiteSmoke"
                                   FontWeight="SemiBold"
                                   FontSize="20"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding EmulatorUpdateNoticeDetails}"
                                   Foreground="#C6C6C6"
                                   FontSize="15"
                                   TextWrapping="Wrap" />
                        <StackPanel Spacing="8"
                                    IsVisible="{Binding HasEmulatorUpdateNoticeChanges}">
                            <TextBlock Text="What's new"
                                       Foreground="WhiteSmoke"
                                       FontWeight="SemiBold"
                                       FontSize="16" />
                            <Border Background="#101010"
                                    BorderBrush="#2A2A2A"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10">
                                <ScrollViewer MaxHeight="200"
                                              HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto">
                                    <TextBlock Text="{Binding EmulatorUpdateNoticeChanges}"
                                               Foreground="#B8B8B8"
                                               FontSize="14"
                                               TextWrapping="Wrap" />
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="{Binding EmulatorUpdateNoticeFooter}"
                                   Foreground="#A8A8A8"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"
                                   Padding="2,8,2,4" />
                    </StackPanel>
                </Border>
                <WrapPanel Orientation="Horizontal" ItemSpacing="8" LineSpacing="8" HorizontalAlignment="Right">
                    <Button Content="Dismiss"
                            Command="{Binding DismissEmulatorUpdateNoticeOverlayCommand}"
                            Padding="14,8"
                            Background="#2B2B2B"
                            Foreground="WhiteSmoke"
                            BorderBrush="DimGray"
                            BorderThickness="1"/>
                    <Button Content="Open updates"
                            Command="{Binding OpenEmulatorUpdateNoticeOverlayCommand}"
                            Padding="14,8"
                            Background="#2B2B2B"
                            Foreground="WhiteSmoke"
                            BorderBrush="DimGray"
                            BorderThickness="1"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="0,360,0,0"
                    Spacing="2"
                    IsHitTestVisible="False">
            <StackPanel.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.3"/>
                </Transitions>
            </StackPanel.Transitions>

            <TextBlock Text="{Binding HighlightedItem.Title, FallbackValue=''}"
                       IsVisible="{Binding IsCarouselVisible}"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       Margin="0,8,0,0"
                       MaxWidth="1000"
                       TextTrimming="CharacterEllipsis"/>
        </StackPanel>

        <!-- Message -->
        <TextBlock Text="{Binding EmptyLoadedAlbumMessage}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextAlignment="Center"
                   FontSize="24"
                   MaxWidth="620"
                   Foreground="#88787878"
                   IsHitTestVisible="False">
            <TextBlock.IsVisible>
                <MultiBinding Converter="{StaticResource BoolAndConverter}">
                    <Binding Path="IsNoAlbumLoadedVisible"/>
                    <Binding Path="IsCarouselVisible"/>
                </MultiBinding>
            </TextBlock.IsVisible>
        </TextBlock>

        <TextBox HorizontalAlignment="Right"
                 VerticalAlignment="Top"
                 Margin="0,15,30,0"
                 IsVisible="{Binding IsSearchBoxVisible}"
                 PlaceholderText="Search"
                 Text="{Binding SearchText, Mode=TwoWay}"
                 Classes="AlbumSearch"
                 ZIndex="100"
                 Cursor="Hand">
            <TextBox.Styles>
                <Style Selector="TextBox.AlbumSearch">
                    <Setter Property="Width" Value="35"/>
                    <Setter Property="Height" Value="35"/>
                    <Setter Property="MinWidth" Value="35"/>
                    <Setter Property="Transitions">
                        <Transitions>
                            <DoubleTransition Property="Width" Duration="0:0:0.35" Easing="CubicEaseOut"/>
                            <ThicknessTransition Property="Padding" Duration="0:0:0.35" Easing="CubicEaseOut"/>
                            <BrushTransition Property="Background" Duration="0:0:0.35"/>
                            <BrushTransition Property="BorderBrush" Duration="0:0:0.35"/>
                        </Transitions>
                    </Setter>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="CornerRadius" Value="18"/>
                    <Setter Property="Padding" Value="0,0,5,0"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="Foreground" Value="Transparent"/>
                </Style>
                <Style Selector="TextBox.AlbumSearch:pointerover, TextBox.AlbumSearch:focus">
                    <Setter Property="Width" Value="220"/>
                    <Setter Property="Background" Value="#AA000000"/>
                    <Setter Property="BorderBrush" Value="#44FFFFFF"/>
                    <Setter Property="Padding" Value="10,0,5,0"/>
                    <Setter Property="Foreground" Value="White"/>
                </Style>
                <Style Selector="TextBox.AlbumSearch /template/ TextBlock#PART_Watermark">
                    <Setter Property="Opacity" Value="0"/>
                    <Setter Property="Transitions">
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                        </Transitions>
                    </Setter>
                </Style>
                <Style Selector="TextBox.AlbumSearch:pointerover /template/ TextBlock#PART_Watermark, TextBox.AlbumSearch:focus /template/ TextBlock#PART_Watermark">
                    <Setter Property="Opacity" Value="0.5"/>
                </Style>
                <Style Selector="TextBox.AlbumSearch /template/ Border#PART_BorderElement">
                    <Setter Property="CornerRadius" Value="18"/>
                    <Setter Property="Transitions">
                        <Transitions>
                            <BrushTransition Property="Background" Duration="0:0:0.35"/>
                            <BrushTransition Property="BorderBrush" Duration="0:0:0.35"/>
                        </Transitions>
                    </Setter>
                </Style>
            </TextBox.Styles>

            <TextBox.InnerLeftContent>
                <Path Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"
                      Fill="#CCFFFFFF"
                      Stretch="Uniform"
                      Width="16"
                      Height="16"
                      Margin="10,0,5,0"
                      VerticalAlignment="Center"
                      IsHitTestVisible="False"/>
            </TextBox.InnerLeftContent>

            <TextBox.InnerRightContent>
                <Button Command="{Binding ClearSearchCommand}"
                        IsVisible="{Binding SearchText, Converter={StaticResource StringNotEmptyToBoolConverter}}"
                        Background="Transparent"
                        Margin="0,0,5,0"
                        Width="25"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate>
                            <Path Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                                  Fill="#AAFFFFFF"
                                  Stretch="Uniform"
                                  Width="10"
                                  Height="10"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </TextBox.InnerRightContent>
        </TextBox>

        <Grid Grid.Row="1" Height="140" Background="#E6000000">
            <Separator Margin="0" VerticalAlignment="Top"/>
            <StackPanel Orientation="Horizontal" Spacing="50" HorizontalAlignment="Left">
                <Button Height="60"
                        Cursor="Hand"
                        VerticalAlignment="Center"
                        Command="{Binding ToggleAlbumListCommand}"
                        Margin="50,0,0,0"
                        ToolTip.Tip="{Binding IsAlbumListCollapsed, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Show Albums, Hide Albums'}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" BorderThickness="0">
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Viewbox Stretch="Uniform">
                        <Canvas Width="100" Height="100">
                            <Rectangle Canvas.Left="18" Canvas.Top="15" Width="64" Height="8" RadiusX="4" RadiusY="4"
                                       Fill="{Binding IsAlbumListCollapsed, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='DimGray,#F0F0F0'}">
                                <Rectangle.Transitions>
                                    <Transitions>
                                        <BrushTransition Property="Fill" Duration="0:0:0.32" />
                                    </Transitions>
                                </Rectangle.Transitions>
                            </Rectangle>
                            <Rectangle Canvas.Left="10" Canvas.Top="30" Width="80" Height="58" RadiusX="12" RadiusY="12"
                                       StrokeThickness="6"
                                       Stroke="{Binding IsAlbumListCollapsed, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='DimGray,#F0F0F0'}"
                                       Fill="Transparent">
                                <Rectangle.Transitions>
                                    <Transitions>
                                        <BrushTransition Property="Stroke" Duration="0:0:0.32" />
                                    </Transitions>
                                </Rectangle.Transitions>
                            </Rectangle>
                        </Canvas>
                    </Viewbox>
                </Button>

                <Button Height="60"
                        Cursor="Hand"
                        VerticalAlignment="Center"
                        Command="{Binding ToggleEmulatorViewportCommand}"
                        IsVisible="{Binding IsEmulatorRunning}"
                        ToolTip.Tip="{Binding IsEmulatorViewportVisible, Converter={StaticResource BoolToStringConverter}, ConverterParameter='Show Carousel, Show Emulator'}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" BorderThickness="0">
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Viewbox Stretch="Uniform" Margin="6">
                        <StackPanel Height="100" Orientation="Horizontal" Spacing="15">
                            <Rectangle Width="6" Height="76" Fill="{Binding IsEmulatorViewportVisible, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='DimGray,#F0F0F0'}">
                                <Rectangle.Transitions>
                                    <Transitions>
                                        <BrushTransition Property="Fill" Duration="0:0:0.32" />
                                    </Transitions>
                                </Rectangle.Transitions>
                            </Rectangle>
                            <Rectangle Width="90" Height="80" RadiusX="16" RadiusY="16" StrokeThickness="6" Stroke="{Binding IsEmulatorViewportVisible, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='DimGray,#F0F0F0'}" Fill="Transparent">
                                <Rectangle.Transitions>
                                    <Transitions>
                                        <BrushTransition Property="Stroke" Duration="0:0:0.32" />
                                    </Transitions>
                                </Rectangle.Transitions>
                            </Rectangle>
                            <Rectangle Width="6" Height="76" Fill="{Binding IsEmulatorViewportVisible, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='DimGray,#F0F0F0'}">
                                <Rectangle.Transitions>
                                    <Transitions>
                                        <BrushTransition Property="Fill" Duration="0:0:0.32" />
                                    </Transitions>
                                </Rectangle.Transitions>
                            </Rectangle>
                        </StackPanel>
                    </Viewbox>
                </Button>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="50" Margin="0,0,50,0">
                <Button Height="60"
                        Width="60"
                        VerticalAlignment="Center"
                        Cursor="Hand"
                        Command="{Binding ToggleRetroArchErrorOverlayCommand}"
                        ToolTip.Tip="Show RetroArch warning">
                    <Button.IsVisible>
                        <MultiBinding Converter="{StaticResource BoolAndConverter}">
                            <Binding Path="IsEmulatorRunning"/>
                            <Binding Path="HasRetroArchError"/>
                        </MultiBinding>
                    </Button.IsVisible>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" BorderThickness="0">
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Viewbox Stretch="Uniform" Margin="0,2,0,0">
                        <Canvas Width="100" Height="100">
                            <Ellipse Canvas.Left="11" Canvas.Top="11" Width="78" Height="78"
                                     Stroke="DimGray"
                                     StrokeThickness="7"
                                     Fill="Transparent"/>
                            <Rectangle Canvas.Left="47" Canvas.Top="24" Width="6" Height="40" Fill="#FFC107" RadiusX="3" RadiusY="3"/>
                            <Ellipse Canvas.Left="47" Canvas.Top="69" Width="6" Height="6" Fill="#FFC107"/>
                        </Canvas>
                    </Viewbox>
                </Button>

                <Button Height="60"
                        Width="60"
                        VerticalAlignment="Center"
                        Cursor="Hand"
                        Command="{Binding LaunchCurrentSectionHandlerSetupCommand}"
                        IsEnabled="{Binding CanLaunchCurrentSectionHandlerSetup}"
                        IsVisible="{Binding !IsEmulatorRunning}"
                        ToolTip.Tip="{Binding CurrentSectionSetupLaunchToolTip}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" BorderThickness="0">
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Viewbox Stretch="Uniform" Opacity="0.9" Margin="0,6,0,0">
                        <Border Width="120"
                                Height="120"
                                CornerRadius="16"
                                Background="#111111"
                                Opacity="{Binding HasCurrentSectionSetupLaunchIcon, Converter={StaticResource BoolToOpacityConverter}}">
                            <Border.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="Opacity" Duration="0:0:0.35" Easing="CubicEaseOut" />
                                </Transitions>
                            </Border.Transitions>
                            <Image Width="102"
                                   Height="102"
                                   Margin="0,4,0,0"
                                   Stretch="Uniform"
                                   Source="{Binding CurrentSectionSetupLaunchIcon}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                        </Border>
                    </Viewbox>
                </Button>

                <Button Height="60"
                        Width="60"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Cursor="Hand"
                        Command="{Binding ToggleShadPs4CheatsOverlayCommand}"
                        IsVisible="{Binding ShowShadPs4InGameCheatsButton}"
                        ToolTip.Tip="Game cheats">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" BorderThickness="0">
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Viewbox Stretch="Uniform"
                             Opacity="0.9"
                             Margin="4"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center">
                        <Rectangle Width="192"
                                   Height="192"
                                   Fill="{Binding ShadPs4CheatsEditor.IsOpen, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='White,DimGray'}">
                            <Rectangle.OpacityMask>
                                <ImageBrush Source="/Assets/ShadPs4GameCheat.png"
                                            Stretch="Uniform" />
                            </Rectangle.OpacityMask>
                            <Rectangle.Transitions>
                                <Transitions>
                                    <BrushTransition Property="Fill" Duration="0:0:0.32" />
                                </Transitions>
                            </Rectangle.Transitions>
                        </Rectangle>
                    </Viewbox>
                </Button>

                <Button Height="60"
                        Width="60"
                        VerticalAlignment="Center"
                        Cursor="Hand"
                        Command="{Binding ToggleFullscreenCommand}"
                        IsVisible="{Binding IsEmulatorRunning}"
                        ToolTip.Tip="Fullscreen">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" BorderThickness="0">
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Viewbox Stretch="Uniform" Opacity="0.9" Margin="4">
                        <Path Data="M32,48 C23.16,48 16,55.16 16,64 V144 C16,152.84 23.16,160 32,160 H160 C168.84,160 176,152.84 176,144 V64 C176,55.16 168.84,48 160,48 H32 M32,58 H160 C163.31,58 166,60.69 166,64 V144 C166,147.31 163.31,150 160,150 H32 C28.69,150 26,147.31 26,144 V64 C26,60.69 28.69,58 32,58 M104.5,160 L104.5,170 H87.5 C83.36,170 80,173.36 80,177.5 C80,181.64 83.36,185 87.5,185 H104.5 L104.5,185 C108.64,185 112,181.64 112,177.5 L112,160 H104.5 M48,72 L48,84 Q48,96 60,96 L48,96 V72 M144,136 L144,124 Q144,112 132,112 L144,112 V136 Z"
                              Fill="{Binding IsFullscreen, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='White,DimGray'}">
                            <Path.Transitions>
                                <Transitions>
                                    <BrushTransition Property="Fill" Duration="0:0:0.32" />
                                </Transitions>
                            </Path.Transitions>
                        </Path>
                    </Viewbox>
                </Button>

                <Button Height="60"
                        Width="60"
                        Margin="3,5,0,0"
                        VerticalAlignment="Center"
                        Cursor="Hand"
                        Command="{Binding OpenCurrentSectionEdenUpdatesCommand}"
                        IsVisible="{Binding IsCurrentSectionHandlerUpdateAvailable}"
                        ToolTip.Tip="Handler update available">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" BorderThickness="0">
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Viewbox Stretch="Uniform" Opacity="0.95" Margin="4">
                        <Canvas Width="100" Height="100">
                            <Arc Canvas.Left="7" Canvas.Top="8" Width="86" Height="86"
                                 StartAngle="32" SweepAngle="296"
                                 Stroke="White" StrokeThickness="8"/>
                            <Path Data="M50,32 L33,49 C30.8,51.2 32.4,55 35.5,55 H44 V70 C44,73.3 46.7,76 50,76 C53.3,76 56,73.3 56,70 V55 H64.5 C67.6,55 69.2,51.2 67,49 L50,32 Z"
                                  Fill="White"/>
                        </Canvas>
                    </Viewbox>
                </Button>

                <Button Height="60"
                        Width="60"
                        VerticalAlignment="Center"
                        Cursor="Hand"
                        Command="{Binding ToggleRenderOptionsCommand}"
                        IsVisible="{Binding CanShowRenderOptions}"
                        ToolTip.Tip="Render Options">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" BorderThickness="0">
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Viewbox Stretch="Uniform" Opacity="0.9" Margin="4">
                        <Path Data="M93.3,130.7c0-10.3,8.4-18.7,18.7-18.7h60.4c6.1-23,27.2-40,52.2-40s46.1,17,52.2,40h121.9c10.3,0,18.7,8.4,18.7,18.7s-8.4,18.7-18.7,18.7H276.8c-6.1,23-27.2,40-52.2,40s-46.1-17-52.2-40H112C101.7,149.3,93.3,141,93.3,130.7z M224.6,150.7c11,0,20-9,20-20s-9-20-20-20s-20,9-20,20S213.6,150.7,224.6,150.7z M93.3,381.3c0-10.3,8.4-18.7,18.7-18.7h171.3c6.1-23,27.2-40,52.2-40s46.1,17,52.2,40h12.4c10.3,0,18.7,8.4,18.7,18.7s-8.4,18.7-18.7,18.7h-12.4c-6.1,23-27.2,40-52.2,40s-46.1-17-52.2-40H112C101.7,400,93.3,391.7,93.3,381.3z M335.5,361.3c-11,0-20,9-20,20s9,20,20,20s20-9,20-20S346.5,361.3,335.5,361.3z"
                              Fill="{Binding IsRenderOptionsOpen, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='White,DimGray'}">
                            <Path.Transitions>
                                <Transitions>
                                    <BrushTransition Property="Fill" Duration="0:0:0.32" />
                                </Transitions>
                            </Path.Transitions>
                        </Path>
                    </Viewbox>
                </Button>

                <Button Height="64"
                        Width="64"
                        Margin="0,2,0,0"
                        VerticalAlignment="Center"
                        Cursor="Hand"
                        Command="{Binding CloseEmulatorCommand}"
                        IsVisible="{Binding IsEmulatorRunning}"
                        ToolTip.Tip="Close Emulator">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" BorderThickness="0">
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Viewbox Stretch="Uniform" Opacity="0.9" Margin="4">
                        <Grid Width="24" Height="24">
                            <Path Stroke="White" StrokeThickness="1.5" StrokeLineCap="Round" Fill="Transparent"
                                  Data="M12,3 L12,11 M6.34,7.34 A8,8 0 1,0 17.66,7.34" />
                        </Grid>
                    </Viewbox>
                </Button>
            </StackPanel>
            <Separator Margin="0" VerticalAlignment="Bottom"/>
        </Grid>

        <Grid Grid.Row="2">
            <Separator Margin="0" VerticalAlignment="Top"/>
            <navigation:EmulationListView x:Name="AlbumListView"
                                          Opacity="{Binding !IsAlbumListCollapsed, Converter={StaticResource BoolToOpacityConverter}}"
                                          IsHitTestVisible="{Binding ElementName=RootView, Path=IsAlbumListInteractive}">
                <Interaction.Behaviors>
                    <behaviors:MaxHeightToggleBehavior IsOpen="{Binding IsAlbumListCollapsed}" />
                </Interaction.Behaviors>
                <navigation:EmulationListView.Transitions>
                    <Transitions>
                        <DoubleTransition Property="MaxHeight" Duration="0:0:0.24" Easing="CubicEaseOut"/>
                        <DoubleTransition Property="Opacity" Duration="0:0:0.20" Easing="CubicEaseOut"/>
                    </Transitions>
                </navigation:EmulationListView.Transitions>
            </navigation:EmulationListView>
        </Grid>

        <!-- Metadata overlay for emulation cover/comment editing -->
        <common:EmulationMetadataOverlay Grid.RowSpan="3"
                                           ZIndex="2106"
                                           DataContext="{Binding MetadataService}" />

        <common:MetadataImageSearchOverlay Grid.RowSpan="3"
                                           ZIndex="2107"
                                           DataContext="{Binding MetadataService}" />

        <common:ShadPs4CustomConfigOverlay Grid.RowSpan="3"
                                           ZIndex="2103"
                                           DataContext="{Binding ShadPs4CustomConfigEditor}" />

        <common:Rpcs3CustomConfigOverlay Grid.RowSpan="3"
                                         ZIndex="2106"
                                         DataContext="{Binding Rpcs3CustomConfigEditor}" />

        <common:ShadPs4CheatsOverlay Grid.RowSpan="3"
                                     ZIndex="2105"
                                     DataContext="{Binding ShadPs4CheatsEditor}" />

        <common:XeniaCustomConfigOverlay Grid.RowSpan="3"
                                         ZIndex="2104"
                                         DataContext="{Binding XeniaCustomConfigEditor}" />

        <common:XeniaPatchesOverlay Grid.RowSpan="3"
                                    ZIndex="2101"
                                    DataContext="{Binding}" />

        <common:ShadPs4PatchesOverlay Grid.RowSpan="3"
                                      ZIndex="2102"
                                      DataContext="{Binding}" />

        <common:Rpcs3PatchesOverlay Grid.RowSpan="3"
                                    ZIndex="2107"
                                    DataContext="{Binding}" />

        <common:CemuGraphicPacksOverlay Grid.RowSpan="3"
                                        ZIndex="2108"
                                        DataContext="{Binding}" />

    </Grid>
</UserControl>
