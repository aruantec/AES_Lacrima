<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AES_Lacrima.ViewModels"
             xmlns:controls="using:AES_Controls"
             x:Class="AES_Lacrima.Rpcs3PatchesOverlay"
             x:Name="PatchesOverlayRoot"
             x:DataType="vm:EmulationViewModel"
             IsHitTestVisible="{Binding IsRpcs3PatchesOverlayOpen}"
             IsVisible="{Binding IsRpcs3PatchesOverlayOpen}"
             Opacity="{Binding IsRpcs3PatchesOverlayOpen, Converter={StaticResource BoolToOpacityConverter}}">

    <UserControl.Transitions>
        <Transitions>
            <DoubleTransition Property="Opacity" Duration="0:0:0.32" />
        </Transitions>
    </UserControl.Transitions>

    <Grid Background="#E6000000">
        <Grid RowDefinitions="Auto,*,Auto" Margin="24,16,24,20">
            <StackPanel Grid.Row="0" Spacing="4" Margin="6,0,0,12">
                <TextBlock Text="{Binding Rpcs3PatchOverlayHeader}"
                           FontSize="42"
                           FontWeight="SemiBold"
                           Foreground="White" />
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <TextBlock Text="Title ID" Foreground="#D8D8D8" FontSize="20" />
                    <TextBlock Text="{Binding Rpcs3DetectedTitleId, FallbackValue=Unknown, TargetNullValue=Unknown}"
                               Foreground="White"
                               FontSize="20" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <TextBlock Text="App version" Foreground="#D8D8D8" FontSize="20" />
                    <TextBlock Text="{Binding Rpcs3DetectedAppVersion, FallbackValue=Unknown, TargetNullValue=Unknown}"
                               Foreground="White"
                               FontSize="20" />
                </StackPanel>
            </StackPanel>

            <Border Grid.Row="1"
                    Background="#1AFFFFFF"
                    BorderBrush="#3FFFFFFF"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12">
                <Grid>
                    <controls:LoadingControl Width="72"
                                             Height="72"
                                             Foreground="#FFFFFFFF"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             IsVisible="{Binding IsRpcs3PatchesBusy}" />

                    <Grid RowDefinitions="Auto,*" RowSpacing="8"
                          IsVisible="{Binding !IsRpcs3PatchesBusy}">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <TextBlock Text="{Binding Rpcs3PatchesSectionLabel}"
                                       Foreground="White"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Button Content="{Binding Rpcs3DownloadPatchesButtonText}"
                                        Command="{Binding DownloadCurrentSectionRpcs3PatchesCommand}"
                                        IsEnabled="{Binding !IsRpcs3PatchesBusy}"
                                        Padding="12,6" />
                                <Button Content="Enable All"
                                        Command="{Binding SelectAllCurrentSectionRpcs3PatchesCommand}"
                                        IsEnabled="{Binding !IsRpcs3PatchesBusy}"
                                        Padding="12,6" />
                                <Button Content="Disable All"
                                        Command="{Binding UnselectAllCurrentSectionRpcs3PatchesCommand}"
                                        IsEnabled="{Binding !IsRpcs3PatchesBusy}"
                                        Padding="12,6" />
                            </StackPanel>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding CurrentSectionRpcs3PatchEntries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:Rpcs3PatchEntry">
                                        <Border Background="#14000000"
                                                BorderBrush="#33FFFFFF"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="12"
                                                Margin="0,0,0,8">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                <StackPanel Grid.Column="0" Spacing="4">
                                                    <TextBlock Text="{Binding Name}"
                                                               Foreground="White"
                                                               FontSize="20"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding Subtitle}"
                                                               Foreground="#B0B0B0"
                                                               FontSize="15"
                                                               TextWrapping="Wrap"
                                                               IsVisible="{Binding Subtitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                </StackPanel>
                                                <ToggleSwitch Grid.Column="1"
                                                              IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                              VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10" Margin="6,12,0,0">
                <TextBlock Grid.Column="0"
                           Text="{Binding Rpcs3PatchesStatus}"
                           Foreground="#D8D8D8"
                           FontSize="18"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Content="Save"
                        Command="{Binding SaveCurrentSectionRpcs3PatchesCommand}"
                        IsEnabled="{Binding !IsRpcs3PatchesBusy}"
                        Padding="14,8" />
                <Button Grid.Column="2"
                        Content="Close"
                        Command="{Binding CloseCurrentSectionRpcs3PatchesCommand}"
                        IsEnabled="{Binding !IsRpcs3PatchesBusy}"
                        Padding="14,8" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>
