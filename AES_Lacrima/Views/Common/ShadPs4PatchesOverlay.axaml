<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AES_Lacrima.ViewModels"
             xmlns:shad="using:AES_Lacrima.Services.ShadPs4"
             xmlns:controls="using:AES_Controls"
             x:Class="AES_Lacrima.ShadPs4PatchesOverlay"
             x:Name="PatchesOverlayRoot"
             x:DataType="vm:EmulationViewModel"
             IsHitTestVisible="{Binding IsShadPs4PatchesOverlayOpen}"
             IsVisible="{Binding IsShadPs4PatchesOverlayOpen}"
             Opacity="{Binding IsShadPs4PatchesOverlayOpen, Converter={StaticResource BoolToOpacityConverter}}">

    <UserControl.Transitions>
        <Transitions>
            <DoubleTransition Property="Opacity" Duration="0:0:0.32" />
        </Transitions>
    </UserControl.Transitions>

    <Grid Background="#E6000000">
        <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="24,16,24,20">
            <StackPanel Grid.Row="0" Spacing="4" Margin="6,0,0,12">
                <TextBlock Text="{Binding ShadPs4PatchOverlayHeader}"
                           FontSize="42"
                           FontWeight="SemiBold"
                           Foreground="White" />
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <TextBlock Text="Title ID" Foreground="#D8D8D8" FontSize="20" />
                    <TextBlock Text="{Binding ShadPs4DetectedTitleId, FallbackValue=Unknown, TargetNullValue=Unknown}"
                               Foreground="White"
                               FontSize="20" />
                </StackPanel>
            </StackPanel>

            <Border Grid.Row="1"
                    Background="#1AFFFFFF"
                    BorderBrush="#3FFFFFFF"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12">
                <Grid>
                    <controls:LoadingControl Width="72"
                                             Height="72"
                                             Foreground="#FFFFFFFF"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             IsVisible="{Binding IsShadPs4PatchesBusy}" />

                    <Grid ColumnDefinitions="280,*"
                          ColumnSpacing="12"
                          IsVisible="{Binding !IsShadPs4PatchesBusy}">
                        <Grid Grid.Column="0" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="8">
                            <TextBlock Text="Patch Files"
                                       Foreground="White"
                                       FontSize="22"
                                       FontWeight="SemiBold" />
                            <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                <TextBlock Text="Repository"
                                           Foreground="#D8D8D8"
                                           FontSize="16"
                                           VerticalAlignment="Center" />
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding ShadPs4PatchRepositories}"
                                          SelectedItem="{Binding SelectedShadPs4PatchRepository, Mode=TwoWay}" />
                                <Button Grid.Column="2"
                                        Content="Download"
                                        Command="{Binding DownloadCurrentSectionShadPs4PatchesCommand}"
                                        IsEnabled="{Binding !IsShadPs4PatchesBusy}"
                                        Padding="12,6" />
                            </Grid>
                            <ListBox Grid.Row="3"
                                     ItemsSource="{Binding CurrentSectionShadPs4PatchFiles}"
                                     SelectedItem="{Binding SelectedCurrentSectionShadPs4PatchFileItem, Mode=TwoWay}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="shad:ShadPs4PatchFileItem">
                                        <TextBlock Text="{Binding TitleId}"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontSize="18" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>

                        <Grid Grid.Column="1" RowDefinitions="Auto,*" RowSpacing="8">
                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                <TextBlock Text="Patches"
                                           Foreground="White"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Content="Enable All"
                                        Command="{Binding SelectAllCurrentSectionShadPs4PatchesCommand}"
                                        IsEnabled="{Binding !IsShadPs4PatchesBusy}"
                                        Padding="12,6" />
                                <Button Grid.Column="2"
                                        Content="Disable All"
                                        Command="{Binding UnselectAllCurrentSectionShadPs4PatchesCommand}"
                                        IsEnabled="{Binding !IsShadPs4PatchesBusy}"
                                        Padding="12,6" />
                            </Grid>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding CurrentSectionShadPs4PatchEntries}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ShadPs4PatchEntry">
                                            <Border Background="#14000000"
                                                    BorderBrush="#33FFFFFF"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="12"
                                                    Margin="0,0,0,8">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                    <StackPanel Grid.Column="0" Spacing="4">
                                                        <TextBlock Text="{Binding Name}"
                                                                   Foreground="White"
                                                                   FontSize="20"
                                                                   FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding Note}"
                                                                   Foreground="#B0B0B0"
                                                                   FontSize="15"
                                                                   TextWrapping="Wrap"
                                                                   IsVisible="{Binding Note, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                        <TextBlock Text="{Binding AppVer, StringFormat='App version: {0}'}"
                                                                   Foreground="#909090"
                                                                   FontSize="14"
                                                                   IsVisible="{Binding AppVer, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                                                    </StackPanel>
                                                    <ToggleSwitch Grid.Column="1"
                                                                  IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                                  VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Background="#E61F1F1F"
                    BorderBrush="#66FFFFFF"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Margin="6,0,0,0"
                    IsVisible="{Binding IsShadPs4PatchSwitchPromptVisible}">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                    <TextBlock Grid.Column="0"
                               Text="You have unsaved changes in the current patch file. Save or Skip before switching."
                               Foreground="#F0F0F0"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               FontSize="16" />
                    <Button Grid.Column="1"
                            Content="Save"
                            Command="{Binding SaveAndSwitchCurrentSectionShadPs4PatchFileCommand}"
                            IsEnabled="{Binding !IsShadPs4PatchesBusy}"
                            Padding="14,8" />
                    <Button Grid.Column="2"
                            Content="Skip"
                            Command="{Binding SkipAndSwitchCurrentSectionShadPs4PatchFileCommand}"
                            IsEnabled="{Binding !IsShadPs4PatchesBusy}"
                            Padding="14,8" />
                </Grid>
            </Border>

            <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10" Margin="6,12,0,0">
                <TextBlock Grid.Column="0"
                           Text="{Binding ShadPs4PatchesStatus}"
                           Foreground="#D8D8D8"
                           FontSize="18"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Content="Save"
                        Command="{Binding SaveCurrentSectionShadPs4PatchesCommand}"
                        IsEnabled="{Binding !IsShadPs4PatchesBusy}"
                        Padding="14,8" />
                <Button Grid.Column="2"
                        Content="Close"
                        Command="{Binding CloseCurrentSectionShadPs4PatchesCommand}"
                        IsEnabled="{Binding !IsShadPs4PatchesBusy}"
                        Padding="14,8" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>
