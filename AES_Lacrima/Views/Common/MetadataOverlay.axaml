<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:services="using:AES_Lacrima.Services"
             xmlns:models="using:AES_Code.Models"
             xmlns:vm="using:AES_Lacrima.ViewModels"
             mc:Ignorable="d"
             x:Name="Root"
             x:Class="AES_Lacrima.MetadataOverlay"
             x:DataType="services:MetadataService"
             IsHitTestVisible="{Binding IsMetadataLoaded}"
             IsVisible="{Binding IsMetadataLoaded}"
             Opacity="{Binding IsMetadataLoaded, Converter={StaticResource BoolToOpacityConverter}}">

    <UserControl.Transitions>
        <Transitions>
            <DoubleTransition Property="Opacity" Duration="0:0:0.32" />
        </Transitions>
    </UserControl.Transitions>

    <Design.DataContext>
        <vm:MusicViewModel />
    </Design.DataContext>

    <Grid Background="#E6000000">
        <Grid RowDefinitions="Auto,*,Auto" Margin="24,16,24,20">
            <StackPanel Grid.Row="0" Spacing="4" Margin="6,0,0,12">
                <TextBlock Text="Metadata Editor"
                           FontSize="42"
                           FontWeight="SemiBold"
                           Foreground="White" />
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <TextBlock Text="Title" Foreground="#D8D8D8" FontSize="20" />
                    <TextBlock Text="{Binding Title, FallbackValue=Unknown, TargetNullValue=Unknown}"
                               Foreground="White"
                               FontSize="20" />
                    <TextBlock Text="Artist" Foreground="#D8D8D8" FontSize="20" />
                    <TextBlock Text="{Binding Artists, FallbackValue=Unknown, TargetNullValue=Unknown}"
                               Foreground="White"
                               FontSize="20" />
                </StackPanel>
            </StackPanel>

            <Border Grid.Row="1"
                    Background="#1AFFFFFF"
                    BorderBrush="#3FFFFFFF"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12">
                <Grid ColumnDefinitions="340,*" ColumnSpacing="12">
                    <Grid Grid.Column="0" RowDefinitions="Auto,*" RowSpacing="8">
                        <TextBlock Text="Details"
                                   Foreground="White"
                                   FontSize="22"
                                   FontWeight="SemiBold" />
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="10">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Title" Foreground="#D8D8D8" FontSize="14" />
                                    <TextBox Text="{Binding Title, Mode=TwoWay}" FontSize="16" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Album" Foreground="#D8D8D8" FontSize="14" />
                                    <TextBox Text="{Binding Album, Mode=TwoWay}" FontSize="16" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Artists" Foreground="#D8D8D8" FontSize="14" />
                                    <TextBox Text="{Binding Artists, Mode=TwoWay}" FontSize="16" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Track" Foreground="#D8D8D8" FontSize="14" />
                                    <TextBox Text="{Binding Track, Mode=TwoWay}" FontSize="16" Width="120" HorizontalAlignment="Left" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Year" Foreground="#D8D8D8" FontSize="14" />
                                    <TextBox Text="{Binding Year, Mode=TwoWay}" FontSize="16" Width="120" HorizontalAlignment="Left" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Genre" Foreground="#D8D8D8" FontSize="14" />
                                    <TextBox Text="{Binding Genres, Mode=TwoWay}" FontSize="16" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Comments" Foreground="#D8D8D8" FontSize="14" />
                                    <TextBox Text="{Binding Comment, Mode=TwoWay}" FontSize="16" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Lyrics" Foreground="#D8D8D8" FontSize="14" />
                                    <TextBox Text="{Binding Lyrics, Mode=TwoWay}"
                                             FontSize="16"
                                             TextWrapping="Wrap"
                                             MinHeight="90"
                                             AcceptsReturn="True" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="File Path" Foreground="#D8D8D8" FontSize="14" />
                                    <TextBox Text="{Binding FilePath, Mode=TwoWay}" FontSize="14" TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*" RowSpacing="8">
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                            <TextBlock Text="Images"
                                       Foreground="White"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding MetadataImageKinds}"
                                      SelectedItem="{Binding SelectedImageKind, Mode=TwoWay}"
                                      MinWidth="140"
                                      VerticalAlignment="Center" />
                            <Button Grid.Column="2"
                                    Content="Add Image"
                                    Command="{Binding OpenAddImageDialogCommand}"
                                    Padding="12,6"
                                    VerticalAlignment="Center" />
                        </Grid>

                        <Border Grid.Row="1"
                                Background="#14000000"
                                BorderBrush="#33FFFFFF"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Cover From Clipboard / URL / Web Search"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="SemiBold" />
                                <Grid ColumnDefinitions="*,104,104"
                                      RowDefinitions="Auto,Auto"
                                      ColumnSpacing="8"
                                      RowSpacing="8">
                                    <TextBox Grid.Row="0"
                                             Grid.Column="0"
                                             Text="{Binding AddImageUrl, Mode=TwoWay}"
                                             PlaceholderText="Paste image URL..."
                                             VerticalAlignment="Center" />
                                    <Button Grid.Row="0"
                                            Grid.Column="1"
                                            Content="Add URL"
                                            Command="{Binding AddImageFromUrlCommand}"
                                            Padding="12,6"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center" />
                                    <Button Grid.Row="0"
                                            Grid.Column="2"
                                            Content="Paste"
                                            Command="{Binding PasteImageFromClipboardCommand}"
                                            Padding="12,6"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center" />
                                    <TextBox Grid.Row="1"
                                             Grid.Column="0"
                                             Text="{Binding ImageSearchQuery, Mode=TwoWay}"
                                             PlaceholderText="Search cover images..."
                                             VerticalAlignment="Center" />
                                    <Button Grid.Row="1"
                                            Grid.Column="1"
                                            Content="Search"
                                            Command="{Binding SearchImagesCommand}"
                                            Padding="12,6"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center" />
                                    <Button Grid.Row="1"
                                            Grid.Column="2"
                                            Content="Use Title"
                                            Command="{Binding SearchImagesByTitleCommand}"
                                            Padding="12,6"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Center" />
                                </Grid>
                                <TextBlock Text="{Binding ImageSearchStatus}"
                                           Foreground="#B0B0B0"
                                           FontSize="14"
                                           TextWrapping="Wrap"
                                           IsVisible="{Binding ImageSearchStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                            </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Images}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:TagImageModel">
                                        <Border Background="#14000000"
                                                BorderBrush="#33FFFFFF"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="12"
                                                Margin="0,0,8,8"
                                                Width="220">
                                            <StackPanel Spacing="8">
                                                <ComboBox ItemsSource="{Binding #Root.DataContext.MetadataImageKinds}"
                                                          SelectedItem="{Binding Kind, Mode=TwoWay}"
                                                          HorizontalAlignment="Stretch" />
                                                <Image Source="{Binding PreviewImage}"
                                                       Stretch="UniformToFill"
                                                       Height="160" />
                                                <Button Content="Remove"
                                                        Command="{Binding DeleteImageCommand}"
                                                        HorizontalAlignment="Right"
                                                        Padding="12,6" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10" Margin="6,12,0,0">
                <TextBlock Grid.Column="0"
                           Text="Edit metadata and images for the selected track."
                           Foreground="#D8D8D8"
                           FontSize="18"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1"
                        Content="Save"
                        Command="{Binding SaveMetadataCommand}"
                        Padding="14,8" />
                <Button Grid.Column="2"
                        Content="Close"
                        Command="{Binding CloseMetadataCommand}"
                        Padding="14,8" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>
