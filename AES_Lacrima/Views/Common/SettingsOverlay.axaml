<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:behavors="using:AES_Controls.Behaviors"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:composition="using:AES_Controls.Composition"
             xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AES_Lacrima.ViewModels"
             mc:Ignorable="d"
             x:Class="AES_Lacrima.Views.Common.SettingsOverlay"
             x:DataType="vm:SettingsViewModel"
             ClipToBounds="False">

    <Design.DataContext>
        <vm:SettingsViewModel/>
    </Design.DataContext>

    <Grid Background="Transparent" RowDefinitions="*,Auto">
        <Border Background="Black"
                Height="75"
                BorderBrush="DimGray"
                BorderThickness="0,0,0,0.5"
                VerticalAlignment="Top"
                Margin="-4,-15,2,0"/>
        <TabControl Grid.Row="0" Margin="15,0,0,0" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
            <TabItem Header="UI" FontSize="30">
                <ScrollViewer>
                    <StackPanel Margin="15,20,0,0">
                        <TextBlock Text="Scaling" VerticalAlignment="Center" FontSize="30" Foreground="WhiteSmoke"/>
                        <StackPanel Orientation="Horizontal">
                            <Slider Background="DarkGray"
                                    Width="260"
                                    Minimum="1.0"
                                    Maximum="3.0"
                                    SmallChange="0.01"
                                    LargeChange="0.1"
                                    Value="{Binding ScaleFactor, Mode=TwoWay}" />
                            <TextBlock Text="{Binding ScaleFactor, StringFormat='{} {0:0.00}X'}"
                                        VerticalAlignment="Center"
                                        Margin="8,0"
                                        Foreground="WhiteSmoke"
                                        FontSize="20"/>
                        </StackPanel>
                        <TextBlock Text="Particle count"
                                    VerticalAlignment="Center"
                                    Foreground="WhiteSmoke"
                                    FontSize="20"/>
                        <StackPanel Orientation="Horizontal">
                            <Slider x:Name="ParticleSlider"
                                    Background="DarkGray"
                                    Width="260"
                                    Minimum="10"
                                    Maximum="60000"
                                    SmallChange="10"
                                    LargeChange="30"
                                    Value="{Binding ParticleCount, Mode=TwoWay}" />
                            <TextBlock Text="{Binding ParticleCount, StringFormat='{} {0:0} / 60000'}"
                                        VerticalAlignment="Center"
                                        Margin="8,0"
                                        Foreground="WhiteSmoke"
                                        FontSize="20"/>
                        </StackPanel>
                        <StackPanel Margin="0,15,0,15" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Show Particles" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="20"/>
                            <ToggleSwitch FontSize="20" IsChecked="{Binding ShowParticles, Mode=TwoWay}" Margin="8,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,15">
                            <TextBlock Text="Show Edge Border" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="20"/>
                            <ToggleSwitch FontSize="20" IsChecked="{Binding ShowEdgeBorder, Mode=TwoWay}" Margin="8,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,15">
                            <TextBlock Text="Clock second circle animation" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="20"/>
                            <ToggleSwitch FontSize="20" IsChecked="{Binding ShowSecondCircleAnimation, Mode=TwoWay}" Margin="8,0"/>
                        </StackPanel>
                        <TextBlock Margin="0,15,0,15" Text="ShaderToy" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="30"/>
                        <Separator Margin="0,0,0,15"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Show ShaderToy" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="20"/>
                            <ToggleSwitch FontSize="20" IsChecked="{Binding ShowShaderToy, Mode=TwoWay}" Margin="8,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,15,0,15"
                                    Spacing="10">
                            <TextBlock Text="Current" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="20"/>
                            <ComboBox Width="250" ItemsSource="{Binding ShaderToys}" DisplayMemberBinding="{Binding Name}" FontSize="16" SelectedItem="{Binding SelectedShadertoy}">
                                <Interaction.Behaviors>
                                    <behavors:ComboBoxPopupScaler/>
                                </Interaction.Behaviors>
                            </ComboBox>
                        </StackPanel>

                        <TextBlock Margin="0,15,0,15" Text="UI Background" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="30"/>
                        <Separator Margin="0,0,0,15"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Show Background" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="20"/>
                            <ToggleSwitch FontSize="20" IsChecked="{Binding ShowBackground, Mode=TwoWay}" Margin="8,0"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,15" Spacing="15" IsVisible="{Binding ShowBackground}">
                            <Button Command="{Binding SelectBackgroundImageCommand}" Padding="0" BorderThickness="1" BorderBrush="DimGray">
                                <Panel Width="120" Height="70">
                                    <Image asyncImageLoader:ImageLoader.Source="{Binding BackgroundImagePath}" Stretch="UniformToFill"/>
                                    <Border Background="#80000000" VerticalAlignment="Bottom">
                                        <TextBlock Text="Change" HorizontalAlignment="Center" FontSize="12" Foreground="White"/>
                                    </Border>
                                </Panel>
                            </Button>
                            <TextBlock Text="{Binding BackgroundImagePath}" VerticalAlignment="Center" Foreground="DarkGray" FontSize="12" TextWrapping="Wrap" MaxWidth="200"/>
                        </StackPanel>

                        <Separator Margin="0,10,0,10"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,20" Spacing="10">
                            <Button Content="Open Library Directory"
                                    Command="{Binding OpenLibraryDirectoryCommand}"
                                    Padding="18,10"
                                    FontSize="18"
                                    MinWidth="220"
                                    Background="#2B2B2B"
                                    Foreground="WhiteSmoke"
                                    BorderBrush="DimGray"
                                    BorderThickness="1"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Emulation" FontSize="30">
                <ScrollViewer>
                    <StackPanel Margin="15,20,0,0">
                        <TextBlock Text="Miscellaneous" VerticalAlignment="Center" FontSize="30" Foreground="WhiteSmoke" Margin="0,0,0,10"/>
                        <Separator Margin="0,0,0,15"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,15" Spacing="10">
                            <TextBlock Text="Use first ROM item cover for album tiles" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="20"/>
                            <ToggleSwitch FontSize="20" IsChecked="{Binding EmulationUseFirstItemCover, Mode=TwoWay}" Margin="8,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,15" Spacing="10">
                            <TextBlock Text="Gameplay Autoplay" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="20"/>
                            <ToggleSwitch FontSize="20" IsChecked="{Binding EmulationGameplayAutoplay, Mode=TwoWay}" Margin="8,0"/>
                        </StackPanel>

                        <TextBlock Text="Consoles" VerticalAlignment="Center" FontSize="30" Foreground="WhiteSmoke" Margin="0,15,0,10"/>
                        <Separator Margin="0,0,0,15"/>
                        <TextBlock Text="Expand a console section to configure the supported emulator handlers for it."
                                   Foreground="DarkGray"
                                   FontSize="16"
                                   TextWrapping="Wrap"
                                   MaxWidth="760"
                                   Margin="0,0,0,15"/>

                        <ItemsControl ItemsSource="{Binding EmulationSections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:EmulationSectionItem">
                                    <Border Background="#151515"
                                            BorderBrush="#343434"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Margin="0,0,0,12">
                                        <Grid RowDefinitions="Auto,Auto">
                                            <ToggleButton Grid.Row="0"
                                                          IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          HorizontalAlignment="Stretch"
                                                          HorizontalContentAlignment="Stretch"
                                                          Padding="14">
                                                <Grid ColumnDefinitions="96,*,Auto" ColumnSpacing="14">
                                                    <Border Width="96"
                                                            Height="60"
                                                            CornerRadius="8"
                                                            BorderBrush="#343434"
                                                            BorderThickness="1"
                                                            ClipToBounds="True">
                                                        <Image asyncImageLoader:ImageLoader.Source="{Binding AlbumImagePath}"
                                                               Stretch="UniformToFill"/>
                                                    </Border>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding SectionTitle}"
                                                               VerticalAlignment="Center"
                                                               FontSize="20"
                                                               Foreground="WhiteSmoke"/>
                                                    <Grid Grid.Column="2"
                                                          Width="28"
                                                          Height="28"
                                                          VerticalAlignment="Center">
                                                        <TextBlock Text="+"
                                                                   IsVisible="{Binding !IsExpanded}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="DarkGray"
                                                                   FontSize="24"/>
                                                        <TextBlock Text="-"
                                                                   IsVisible="{Binding IsExpanded}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="DarkGray"
                                                                   FontSize="24"/>
                                                    </Grid>
                                                </Grid>
                                            </ToggleButton>

                                            <StackPanel Grid.Row="1"
                                                        Margin="14,0,14,14"
                                                        Spacing="10"
                                                        IsVisible="{Binding IsExpanded}">
                                                <ItemsControl ItemsSource="{Binding Handlers}"
                                                              IsVisible="{Binding HasHandlers}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:EmulationHandlerAppItem">
                                                            <Border Background="#1D1D1D"
                                                                    BorderBrush="#343434"
                                                                    BorderThickness="1"
                                                                    CornerRadius="8"
                                                                    Padding="12">
                                                                <Grid ColumnDefinitions="180,*,Auto,Auto" ColumnSpacing="12">
                                                                    <TextBlock Text="{Binding DisplayName}"
                                                                               VerticalAlignment="Center"
                                                                               FontSize="18"
                                                                               Foreground="WhiteSmoke"/>
                                                                    <TextBlock Grid.Column="1"
                                                                               Text="{Binding LauncherDisplayPath}"
                                                                               Foreground="DarkGray"
                                                                               FontSize="14"
                                                                               TextWrapping="Wrap"
                                                                               VerticalAlignment="Center"
                                                                               MaxWidth="360"/>
                                                                    <Button Grid.Column="2"
                                                                            Content="Browse"
                                                                            Command="{Binding BrowseLauncherCommand}"
                                                                            Padding="14,8"
                                                                            MinWidth="100"/>
                                                                    <Button Grid.Column="3"
                                                                            Content="Clear"
                                                                            Command="{Binding ClearLauncherCommand}"
                                                                            IsVisible="{Binding HasLauncherPath}"
                                                                            Padding="14,8"
                                                                            MinWidth="90"
                                                                            Background="#3A2020"
                                                                            Foreground="WhiteSmoke"/>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <TextBlock Text="No handlers available yet for this section."
                                                           IsVisible="{Binding !HasHandlers}"
                                                           Foreground="DarkGray"
                                                           FontSize="14"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Updates" FontSize="30">
                <ScrollViewer>
                    <StackPanel Margin="15,20,0,0">
                        <TextBlock Text="Application updates" VerticalAlignment="Center" FontSize="30" Foreground="WhiteSmoke" Margin="0,0,0,10"/>
                        <Separator Margin="0,0,0,15"/>
                        <StackPanel Spacing="5" Margin="0,0,0,15">
                            <TextBlock Text="Updater Status" FontSize="20" Foreground="WhiteSmoke"/>
                            <TextBlock Text="{Binding AppUpdateService.Status}"
                                       FontSize="16"
                                       Foreground="DarkGray"
                                       TextWrapping="Wrap"
                                       MaxWidth="720"
                                       HorizontalAlignment="Left"
                                       TextAlignment="Left"
                                       Margin="0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="18" VerticalAlignment="Center" Margin="0,0,0,15">
                            <TextBlock Text="Check for updates on startup" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="16"/>
                            <ToggleSwitch IsChecked="{Binding CheckForAppUpdatesOnStartup, Mode=TwoWay}"/>
                        </StackPanel>
                        <Grid ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="18" VerticalAlignment="Center" Margin="0,0,0,15">
                            <TextBlock Text="Preferred update build" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="16"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding PreferredAppUpdateFlavorLabel}"
                                       VerticalAlignment="Center"
                                       Foreground="DarkGray"
                                       FontSize="16"/>
                            <ToggleSwitch Grid.Column="2"
                                          IsChecked="{Binding PreferAotAppUpdates, Mode=TwoWay}"/>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,25">
                            <Button Content="Check for App Update"
                                    Command="{Binding CheckForAppUpdateCommand}"
                                    IsEnabled="{Binding !AppUpdateService.IsBusy}"
                                    Padding="15,8"/>
                            <Button Content="Refresh Release History"
                                    Command="{Binding RefreshAppReleaseHistoryCommand}"
                                    IsEnabled="{Binding !AppUpdateService.IsBusy}"
                                    Padding="15,8"/>
                        </StackPanel>
                        <ProgressBar IsIndeterminate="True"
                                     IsVisible="{Binding AppUpdateService.IsChecking}"
                                     Margin="0,0,0,25"
                                     Height="2"
                                     Width="400"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Top"/>
                        <Border Background="#111111"
                                BorderBrush="#343434"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14"
                                MaxWidth="760"
                                HorizontalAlignment="Left"
                                Margin="0">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Install Specific Version"
                                           FontSize="20"
                                           Foreground="WhiteSmoke"/>
                                <TextBlock Text="{Binding SelectedAppReleaseDisplayStatus}"
                                           FontSize="15"
                                           Foreground="DarkGray"
                                           TextWrapping="Wrap"/>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                                    <TextBlock Text="Version"
                                               VerticalAlignment="Center"
                                               Foreground="WhiteSmoke"
                                               FontSize="16"/>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding AvailableAppReleases}"
                                              SelectedItem="{Binding SelectedAppRelease, Mode=TwoWay}"
                                              DisplayMemberBinding="{Binding DisplayLabel}"
                                              IsEnabled="{Binding HasAvailableAppReleases}">
                                        <Interaction.Behaviors>
                                            <behavors:ComboBoxPopupScaler/>
                                        </Interaction.Behaviors>
                                    </ComboBox>
                                </Grid>
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                                    <TextBlock Text="Package"
                                               VerticalAlignment="Center"
                                               Foreground="WhiteSmoke"
                                               FontSize="16"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding SelectedAppReleaseAssetName, FallbackValue='No compatible package selected'}"
                                               VerticalAlignment="Center"
                                               Foreground="#C6C6C6"
                                               TextWrapping="Wrap"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button Content="{Binding SelectedAppReleaseActionLabel}"
                                            Command="{Binding InstallSelectedAppReleaseCommand}"
                                            IsEnabled="{Binding CanInstallSelectedAppRelease}"
                                            Padding="15,8"
                                            Background="Gold"
                                            Foreground="Black"/>
                                </StackPanel>
                                <ProgressBar Height="8"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="{Binding SelectedAppReleaseProgressValue}"
                                             IsVisible="{Binding IsSelectedAppReleaseDownloading}"/>
                                <TextBlock Text="{Binding SelectedAppReleaseProgressText}"
                                           Foreground="#C6C6C6"
                                           IsVisible="{Binding IsSelectedAppReleaseDownloading}"/>
                                <ProgressBar Height="4"
                                             IsIndeterminate="True"
                                             IsVisible="{Binding IsSelectedAppReleasePreparing}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Audio" FontSize="30">
                <ScrollViewer>
                    <StackPanel Margin="15,20,0,0">
                        <TextBlock Text="Spectrum" VerticalAlignment="Center" FontSize="30" Foreground="WhiteSmoke" Margin="0,0,0,10"/>
                        <Grid ColumnDefinitions="Auto, Auto, Auto" RowDefinitions="Auto, Auto, Auto" Margin="0,0,0,8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Height" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="18" Margin="0,8"/>
                            <Slider Grid.Row="0" Grid.Column="1" Width="300" Minimum="50" Maximum="1000" Value="{Binding SpectrumHeight, Mode=TwoWay}" Margin="10,0,0,0"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding SpectrumHeight, StringFormat='{} {0:0}'}" VerticalAlignment="Center" Foreground="WhiteSmoke" Margin="10,0"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Bar Width" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="18" Margin="0,8"/>
                            <Slider Grid.Row="1" Grid.Column="1" Width="300" Minimum="10" Maximum="100" Value="{Binding BarWidth, Mode=TwoWay}" Margin="10,0,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding BarWidth, StringFormat='{} {0:0.##}'}" VerticalAlignment="Center" Foreground="WhiteSmoke" Margin="10,0"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Bar Spacing" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="18" Margin="0,8"/>
                            <Slider Grid.Row="2" Grid.Column="1" Width="300" Minimum="0" Maximum="100" Value="{Binding BarSpacing, Mode=TwoWay}" Margin="10,0,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding BarSpacing, StringFormat='{} {0:0.##}'}" VerticalAlignment="Center" Foreground="WhiteSmoke" Margin="10,0"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,8" VerticalAlignment="Center">
                            <TextBlock Text="Show Spectrum" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="18"/>
                            <ToggleSwitch IsChecked="{Binding ShowMusicSpectrum, Mode=TwoWay}" Margin="8,0"/>
                        </StackPanel>

                        <TextBlock Margin="0,8,0,8" Text="Spectrum Gradient" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="18"/>
                        <WrapPanel Orientation="Horizontal" Margin="0,8,0,8">
                            <ColorPicker Width="80" Height="40" Margin="0,0,10,10" Color="{Binding SpectrumColor0, Mode=TwoWay}"/>
                            <ColorPicker Width="80" Height="40" Margin="0,0,10,10" Color="{Binding SpectrumColor1, Mode=TwoWay}"/>
                            <ColorPicker Width="80" Height="40" Margin="0,0,10,10" Color="{Binding SpectrumColor2, Mode=TwoWay}"/>
                            <ColorPicker Width="80" Height="40" Margin="0,0,10,10" Color="{Binding SpectrumColor3, Mode=TwoWay}"/>
                            <ColorPicker Width="80" Height="40" Margin="0,0,10,10" Color="{Binding SpectrumColor4, Mode=TwoWay}"/>
                        </WrapPanel>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,8,0,8" Spacing="10">
                            <TextBlock Text="Silence advance delay (ms):" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="16"/>
                            <TextBox Width="80" Text="{Binding SilenceAdvanceDelayMs, Mode=TwoWay}">
                                     <Interaction.Behaviors>
                                         <behavors:DigitOnlyBehavior/>
                                     </Interaction.Behaviors>
                                </TextBox>
                        </StackPanel>

                        <TextBlock Margin="0,18,0,8" Text="ReplayGain / Normalization" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="18"/>
                        <StackPanel Orientation="Vertical" Margin="0,0,0,10">
                            <StackPanel Orientation="Vertical" Spacing="6" Margin="0,4,0,12">
                                <CheckBox IsChecked="{Binding SmoothVolumeChange, Mode=TwoWay}">
                                    <TextBlock Text="Smooth volume changing" Foreground="WhiteSmoke" VerticalAlignment="Center"/>
                                </CheckBox>
                                <CheckBox IsChecked="{Binding LogarithmicVolumeControl, Mode=TwoWay}">
                                    <TextBlock Text="Logarithmic volume control" Foreground="WhiteSmoke" VerticalAlignment="Center"/>
                                </CheckBox>
                                <CheckBox IsChecked="{Binding LoudnessCompensatedVolume, Mode=TwoWay}">
                                    <TextBlock Text="Loudness compensated volume control" Foreground="WhiteSmoke" VerticalAlignment="Center"/>
                                </CheckBox>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                                <TextBlock Text="Enable ReplayGain" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="16"/>
                                <ToggleSwitch IsChecked="{Binding ReplayGainEnabled, Mode=TwoWay}"/>
                            </StackPanel>

                            <StackPanel Orientation="Vertical" Margin="0,8,0,0" Spacing="4">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                                    <CheckBox IsChecked="{Binding ReplayGainAnalyzeOnTheFly, Mode=TwoWay}" VerticalAlignment="Center"/>
                                    <TextBlock Text="Analyse file on-the-fly" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="14"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                                    <TextBlock Text="Preamp (dB):" VerticalAlignment="Center" Foreground="WhiteSmoke"/>
                                    <Slider Width="220" Minimum="-12" Maximum="12" Value="{Binding ReplayGainPreampDb, Mode=TwoWay}"/>
                                    <TextBlock Text="{Binding ReplayGainPreampDb, StringFormat='{} {0:0.##} dB'}" VerticalAlignment="Center" Foreground="WhiteSmoke" Margin="8,0,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Orientation="Vertical" Margin="0,8,0,0" Spacing="4">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                                    <CheckBox IsChecked="{Binding ReplayGainUseTags, Mode=TwoWay}" VerticalAlignment="Center"/>
                                    <TextBlock Text="Use value from tags" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="14"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                                    <TextBlock Text="Preamp (dB):" VerticalAlignment="Center" Foreground="WhiteSmoke"/>
                                    <Slider Width="180" Minimum="-12" Maximum="12" Value="{Binding ReplayGainTagsPreampDb, Mode=TwoWay}"/>
                                    <TextBlock Text="{Binding ReplayGainTagsPreampDb, StringFormat='{} {0:0.##} dB'}" VerticalAlignment="Center" Foreground="WhiteSmoke" Margin="8,0,0,0"/>
                                    <ComboBox Width="120" SelectedIndex="{Binding ReplayGainTagSource, Mode=TwoWay}" Margin="12,0,0,0">
                                        <ComboBoxItem>Track</ComboBoxItem>
                                        <ComboBoxItem>Album</ComboBoxItem>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Carousel" FontSize="30">
                <StackPanel Margin="15,20,0,0">
                    <TextBlock Text="Setup" VerticalAlignment="Center" FontSize="30" Foreground="WhiteSmoke" Margin="0,0,0,10"/>
                    <Grid ColumnDefinitions="Auto, 320, Auto, *" RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto" Margin="0,0,0,8" HorizontalAlignment="Stretch" ClipToBounds="False">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Item Spacing" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="18" Margin="0,6"/>
                        <Slider Grid.Row="0" Grid.Column="1" Width="260" HorizontalAlignment="Center" Minimum="0.2" Maximum="3.0" SmallChange="0.01" LargeChange="0.1" Value="{Binding CarouselSpacing, Mode=TwoWay}" Margin="0,0"/>
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding CarouselSpacing, StringFormat='{}{0:0.00}'}" VerticalAlignment="Center" Foreground="WhiteSmoke" Margin="10,0"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Item Scale" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="18" Margin="0,6"/>
                        <Slider Grid.Row="1" Grid.Column="1" Width="260" HorizontalAlignment="Center" Minimum="0.5" Maximum="2.0" SmallChange="0.01" LargeChange="0.1" Value="{Binding CarouselScale, Mode=TwoWay}" Margin="0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding CarouselScale, StringFormat='{}{0:0.00}X'}" VerticalAlignment="Center" Foreground="WhiteSmoke" Margin="10,0"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Vertical Offset" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="18" Margin="0,6"/>
                        <Slider Grid.Row="2" Grid.Column="1" Width="260" HorizontalAlignment="Center" Minimum="-400" Maximum="400" SmallChange="1" LargeChange="10" Value="{Binding CarouselVerticalOffset, Mode=TwoWay}" Margin="0,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding CarouselVerticalOffset, StringFormat='{}{0:0}'}" VerticalAlignment="Center" Foreground="WhiteSmoke" Margin="10,0"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Slider Vertical Offset" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="18" Margin="0,6"/>
                        <Slider Grid.Row="3" Grid.Column="1" Width="260" HorizontalAlignment="Center" Minimum="0" Maximum="1080" SmallChange="1" LargeChange="5" Value="{Binding CarouselSliderVerticalOffset, Mode=TwoWay}" Margin="0,0"/>
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding CarouselSliderVerticalOffset, StringFormat='{}{0:0}'}" VerticalAlignment="Center" Foreground="WhiteSmoke" Margin="10,0"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Slider Track Height" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="18" Margin="0,6"/>
                        <Slider Grid.Row="4" Grid.Column="1" Width="260" HorizontalAlignment="Center" Minimum="1" Maximum="40" SmallChange="1" LargeChange="2" Value="{Binding CarouselSliderTrackHeight, Mode=TwoWay}" Margin="0,0"/>
                        <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding CarouselSliderTrackHeight, StringFormat='{}{0:0}'}" VerticalAlignment="Center" Foreground="WhiteSmoke" Margin="10,0"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Side Translation" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="18" Margin="0,6"/>
                        <Slider Grid.Row="5" Grid.Column="1" Width="260" HorizontalAlignment="Center" Minimum="0" Maximum="1000" SmallChange="1" LargeChange="10" Value="{Binding CarouselSideTranslation, Mode=TwoWay}" Margin="0,0"/>
                        <TextBlock Grid.Row="5" Grid.Column="2" Text="{Binding CarouselSideTranslation, StringFormat='{}{0:0}'}" VerticalAlignment="Center" Foreground="WhiteSmoke" Margin="10,0"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Stack Spacing" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="18" Margin="0,6"/>
                        <Slider Grid.Row="6" Grid.Column="1" Width="260" HorizontalAlignment="Center" Minimum="0" Maximum="400" SmallChange="1" LargeChange="10" Value="{Binding CarouselStackSpacing, Mode=TwoWay}" Margin="0,0"/>
                        <TextBlock Grid.Row="6" Grid.Column="2" Text="{Binding CarouselStackSpacing, StringFormat='{}{0:0}'}" VerticalAlignment="Center" Foreground="WhiteSmoke" Margin="10,0"/>

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Full Cover Size" VerticalAlignment="Center" Foreground="WhiteSmoke" FontSize="18" Margin="0,6"/>
                        <ToggleSwitch Grid.Row="7" Grid.Column="1" IsChecked="{Binding CarouselUseFullCoverSize, Mode=TwoWay}" HorizontalAlignment="Left" Margin="30,0,0,0"/>
                    </Grid>
                </StackPanel>
            </TabItem>

            <TabItem Header="Libraries" FontSize="30">
                <ScrollViewer>
                    <StackPanel Margin="15,20,0,0">
                        <TextBlock Text="External tools" VerticalAlignment="Center" FontSize="30" Foreground="WhiteSmoke" Margin="0,0,0,10"/>
                        <Separator Margin="0,0,0,15"/>
                        <StackPanel Spacing="5" Margin="0,0,0,15">
                            <TextBlock Text="FFmpeg Status" FontSize="20" Foreground="WhiteSmoke"/>
                            <TextBlock Text="{Binding FfmpegManager.Status}" FontSize="16" Foreground="DarkGray"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="40" Margin="0,0,0,25">
                            <StackPanel Spacing="5">
                                <TextBlock Text="CURRENT VERSION" FontSize="14" Foreground="DarkGray" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding FfmpegVersion, FallbackValue='Not Found'}" FontSize="18" Foreground="WhiteSmoke"/>
                            </StackPanel>
                            <StackPanel Spacing="5" IsVisible="{Binding IsFfmpegUpdateAvailable}">
                                <TextBlock Text="UPDATE AVAILABLE" FontSize="14" Foreground="Gold" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding FfmpegUpdateVersion}" FontSize="18" Foreground="Gold"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Content="Install FFmpeg" Command="{Binding InstallFFmpegCommand}" IsVisible="{Binding !IsFfmpegInstalled}" IsEnabled="{Binding !FfmpegManager.IsBusy}" Padding="15,8"/>
                            <Button Content="Update" Command="{Binding UpdateFFmpegCommand}" IsVisible="{Binding IsFfmpegUpdateAvailable}" IsEnabled="{Binding !FfmpegManager.IsBusy}" Padding="15,8" Background="Gold" Foreground="Black"/>
                            <Button Content="Uninstall" Background="#F44336" Foreground="White" Command="{Binding UninstallFFmpegCommand}" IsVisible="{Binding IsFfmpegInstalled}" IsEnabled="{Binding !FfmpegManager.IsBusy}" Padding="15,8"/>
                            <Button Content="Check for Updates" Command="{Binding RefreshFFmpegInfoCommand}" IsEnabled="{Binding !FfmpegManager.IsBusy}" Padding="15,8"/>
                        </StackPanel>
                        <ProgressBar IsIndeterminate="True" IsVisible="{Binding FfmpegManager.IsBusy}" Margin="0,30,0,0" Height="2" Width="400" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <TextBlock Text="libmpv Status" FontSize="20" Foreground="WhiteSmoke" Margin="0,30,0,10"/>
                        <Separator Margin="0,0,0,15"/>
                        <StackPanel Spacing="10" Margin="0,0,0,15">
                            <TextBlock Text="{Binding MpvManager.Status}" FontSize="16" Foreground="DarkGray"/>
                            <StackPanel Orientation="Horizontal" Spacing="40" Margin="0,0,0,10" IsVisible="{Binding IsMpvInstalled}">
                                <StackPanel Spacing="5">
                                    <TextBlock Text="CURRENT VERSION" FontSize="14" Foreground="DarkGray" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding MpvVersion, FallbackValue='Not Found'}" FontSize="18" Foreground="WhiteSmoke"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="20">
                                <TextBlock Text="Available Versions (Win builds)" VerticalAlignment="Center" FontSize="16" Foreground="WhiteSmoke"/>
                                <ComboBox Width="300" ItemsSource="{Binding AvailableMpvVersions}" SelectedItem="{Binding SelectedMpvVersion}" FontSize="14">
                                    <Interaction.Behaviors>
                                        <behavors:ComboBoxPopupScaler/>
                                    </Interaction.Behaviors>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Content="Install" Command="{Binding InstallMpvCommand}" IsVisible="{Binding !IsMpvInstalled}" IsEnabled="{Binding !MpvManager.IsBusy}" Padding="15,8"/>
                            <Button Content="Force Reinstall Specific" Command="{Binding InstallSpecificMpvVersionCommand}" IsEnabled="{Binding !MpvManager.IsBusy}" Padding="15,8" Background="Gold" Foreground="Black"/>
                            <Button Content="Uninstall libmpv" Background="#F44336" Foreground="White" Command="{Binding UninstallMpvCommand}" IsVisible="{Binding IsMpvInstalled}" IsEnabled="{Binding !MpvManager.IsBusy}" Padding="15,8"/>
                            <Button Content="Refresh libmpv Info" Command="{Binding RefreshMpvInfoCommand}" IsEnabled="{Binding !MpvManager.IsBusy}" Padding="15,8"/>
                        </StackPanel>
                        <ProgressBar IsIndeterminate="True" IsVisible="{Binding MpvManager.IsBusy}" Margin="0,30,0,0" Height="2" Width="400" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <TextBlock Text="yt-dlp Status" FontSize="20" Foreground="WhiteSmoke" Margin="0,30,0,10"/>
                        <Separator Margin="0,0,0,15"/>
                        <StackPanel Spacing="10" Margin="0,0,0,15">
                            <TextBlock Text="{Binding YtDlp.Status}" FontSize="16" Foreground="DarkGray"/>
                            <StackPanel Orientation="Horizontal" Spacing="40" Margin="0,0,0,10">
                                <StackPanel Spacing="5">
                                    <TextBlock Text="CURRENT VERSION" FontSize="14" Foreground="DarkGray" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding YtDlpVersion, FallbackValue='Not Found'}" FontSize="18" Foreground="WhiteSmoke"/>
                                </StackPanel>
                                <StackPanel Spacing="5" IsVisible="{Binding IsYtDlpUpdateAvailable}">
                                    <TextBlock Text="UPDATE AVAILABLE" FontSize="14" Foreground="Gold" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding YtDlpUpdateVersion}" FontSize="18" Foreground="Gold"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Content="Install yt-dlp" Command="{Binding InstallYtDlpCommand}" IsVisible="{Binding !IsYtDlpInstalled}" IsEnabled="{Binding !YtDlp.IsBusy}" Padding="15,8"/>
                            <Button Content="Update" Command="{Binding UpdateYtDlpCommand}" IsVisible="{Binding IsYtDlpUpdateAvailable}" IsEnabled="{Binding !YtDlp.IsBusy}" Padding="15,8" Background="Gold" Foreground="Black"/>
                            <Button Content="Uninstall" Background="#F44336" Foreground="White" Command="{Binding UninstallYtDlpCommand}" IsVisible="{Binding IsYtDlpInstalled}" IsEnabled="{Binding !YtDlp.IsBusy}" Padding="15,8"/>
                            <Button Content="Check for Updates" Command="{Binding RefreshYtDlpInfoCommand}" IsEnabled="{Binding !YtDlp.IsBusy}" Padding="15,8"/>
                        </StackPanel>
                        <ProgressBar IsIndeterminate="True" IsVisible="{Binding YtDlp.IsBusy}" Margin="0,30,0,0" Height="2" Width="400" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
        <Border Grid.Row="1"
                Margin="15,8,12,6"
                Padding="0,10,0,2"
                BorderBrush="#33FFFFFF"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                <Border Background="Transparent"/>
                <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Right">
                    <TextBlock Text="CURRENT VERSION"
                               FontSize="12"
                               Foreground="DarkGray"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Right"/>
                    <TextBlock Text="{Binding AppUpdateService.CurrentVersionDisplay, FallbackValue='Unknown'}"
                               FontSize="16"
                               Foreground="WhiteSmoke"
                               HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
