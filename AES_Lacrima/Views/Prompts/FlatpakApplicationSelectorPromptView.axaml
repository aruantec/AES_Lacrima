<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:AES_Lacrima.ViewModels.Prompts"
             mc:Ignorable="d"
             d:DesignWidth="860"
             d:DesignHeight="540"
             x:Class="AES_Lacrima.Views.Prompts.FlatpakApplicationSelectorPromptView"
             x:DataType="vm:FlatpakApplicationSelectorPromptViewModel">
    <Grid Background="#B3000000" Grid.ColumnDefinitions="18*,64*,18*">
        <Border Grid.Column="1"
                Background="#151515"
                BorderBrush="#3E3E42"
                BorderThickness="1"
                CornerRadius="12"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                MaxWidth="900"
                MinWidth="760">
            <Grid RowDefinitions="Auto,*,Auto">
                <StackPanel Margin="28,24,28,14" Spacing="10">
                    <TextBlock Text="{Binding Title}"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="{Binding Message}"
                               FontSize="18"
                               Foreground="#E8E8E8"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="28,0,28,0"
                        Background="#202020"
                        BorderBrush="#303030"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10">
                    <Grid>
                        <ListBox ItemsSource="{Binding Applications}"
                                 SelectedItem="{Binding SelectedApplication, Mode=TwoWay}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 IsVisible="{Binding HasApplications}">
                            <ListBox.Styles>
                                <Style Selector="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListBox.Styles>
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:FlatpakApplicationItem">
                                    <Border Margin="0,0,0,8"
                                            Padding="14"
                                            Background="#252525"
                                            BorderBrush="#303030"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            HorizontalAlignment="Stretch"
                                            ToolTip.Tip="{Binding DesktopFilePath}">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding DisplayLabel}"
                                                       FontSize="16"
                                                       Foreground="White"/>
                                            <TextBlock Text="{Binding ApplicationId}"
                                                       FontSize="13"
                                                       Foreground="#BDBDBD"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel IsVisible="{Binding !HasApplications}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="6">
                            <TextBlock Text="No Flatpak applications were detected."
                                       FontSize="18"
                                       Foreground="#D0D0D0"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Install or export a Flatpak application, then try again."
                                       FontSize="14"
                                       Foreground="#9A9A9A"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       MaxWidth="500"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="28,18,28,24"
                            Spacing="10">
                    <Button Content="CANCEL"
                            Command="{Binding CloseCommand}"
                            Background="Transparent"
                            BorderBrush="#555555"
                            Width="110"/>
                    <Button Content="USE SELECTED APP"
                            Command="{Binding SelectCommand}"
                            Background="#007ACC"
                            Foreground="White"
                            FontWeight="Bold"
                            Width="180"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>