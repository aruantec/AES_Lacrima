<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:behaviors="using:AES_Controls.Behaviors"
             xmlns:composition="using:AES_Controls.Composition"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:Interaction="http://avaloniaui.net/schemas/2019/interactivity"
             xmlns:vm="using:AES_Lacrima.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             x:Class="AES_Lacrima.Views.Navigation.EmulationListView"
             x:DataType="vm:EmulationViewModel"
             ClipToBounds="False"
             Height="266">

    <Design.DataContext>
        <vm:EmulationViewModel/>
    </Design.DataContext>

    <Grid Background="Black" ClipToBounds="False">
        <ListBox ItemsSource="{Binding AlbumList}"
                 Background="Transparent"
                 ClipToBounds="False"
                 SelectionMode="Single"
                 SelectedIndex="{Binding SelectedAlbumIndex, Mode=TwoWay}"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                 Margin="0,8,0,10">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="ClipToBounds" Value="False"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Style Selector="^ /template/ ContentPresenter">
                        <Setter Property="ClipToBounds" Value="False"/>
                    </Style>
                    <Style Selector="^ /template/ Border#LayoutRoot">
                        <Setter Property="ClipToBounds" Value="False"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                    <Style Selector="^ /template/ Border">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                    <Style Selector="^ /template/ ContentPresenter">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </Style>
                <Style Selector="ListBoxItem:pointerover">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
                <Style Selector="ListBoxItem:selected">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
                <Style Selector="ListBoxItem:selected:pointerover">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
                <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                    <Setter Property="Background" Value="Transparent"/>
                </Style>
                <Style Selector="ListBoxItem:selected /template/ ContentPresenter Border#SelectionOverlay">
                    <Setter Property="Opacity" Value="0"/>
                </Style>
                <Style Selector="Border.SelectionHighlight">
                    <Setter Property="Opacity" Value="0"/>
                </Style>
                <Style Selector="ListBoxItem:selected Border.SelectionHighlight">
                    <Setter Property="Opacity" Value="1"/>
                </Style>
                <Style Selector="ListBoxItem:pointerover Border.SelectionHighlight">
                    <Setter Property="Opacity" Value="0.6"/>
                </Style>
                <Style Selector="ListBoxItem:selected:pointerover Border.SelectionHighlight">
                    <Setter Property="Opacity" Value="1"/>
                </Style>
                <Style Selector="ListBox /template/ ScrollContentPresenter">
                    <Setter Property="ClipToBounds" Value="False"/>
                </Style>
                <Style Selector="ListBox /template/ ItemsPresenter">
                    <Setter Property="ClipToBounds" Value="False"/>
                </Style>
                <Style Selector="ListBox /template/ ScrollViewer">
                    <Setter Property="ClipToBounds" Value="False"/>
                </Style>
                <Style Selector="ListBox /template/ Border">
                    <Setter Property="ClipToBounds" Value="False"/>
                </Style>
            </ListBox.Styles>

            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:EmulationAlbumItem">
                    <Border CornerRadius="12" Margin="0" ClipToBounds="False" Background="Transparent">
                        <Grid Width="240" Height="220">
                            <Border CornerRadius="12"
                                    Background="#111111"
                                    BorderBrush="#1A1A1A"
                                    BorderThickness="2"
                                    IsHitTestVisible="False"/>

                            <Border HorizontalAlignment="Stretch"
                                    VerticalAlignment="Stretch"
                                    Margin="0"
                                    CornerRadius="12"
                                    ClipToBounds="True"
                                    Background="Transparent">
                                <composition:FolderCompositionControl Items="{Binding PreviewItems}"
                                                                      FolderCoverItem="{Binding}"
                                                                      DefaultCover="{Binding CoverBitmap}"
                                                                      ClipToBounds="True"
                                                                      MaxVisibleCovers="1"
                                                                      CoverStretch="UniformToFill"/>
                            </Border>

                            <Border VerticalAlignment="Bottom"
                                    Height="50"
                                    Background="#CC000000"
                                    ClipToBounds="True"
                                    CornerRadius="0,0,12,12">
                                <Grid Margin="8,4">
                                    <TextBlock Text="{Binding Title}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"
                                               Foreground="White"
                                               FontSize="18"
                                                MaxLines="2"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </Border>

                            <Border Classes="SelectionHighlight"
                                    Background="#440078D7"
                                    BorderBrush="#880078D7"
                                    BorderThickness="2"
                                    IsHitTestVisible="False"
                                    CornerRadius="12">
                                <Border.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Opacity" Duration="0:0:0.15" Easing="CubicEaseOut"/>
                                    </Transitions>
                                </Border.Transitions>
                            </Border>

                            <Border VerticalAlignment="Top"
                                    HorizontalAlignment="Right"
                                    Margin="12"
                                    Padding="6,2"
                                    MinWidth="24"
                                    MinHeight="24"
                                    CornerRadius="12"
                                    Background="#222222"
                                    IsHitTestVisible="False"
                                    BoxShadow="0 2 5 0 #41000000"
                                    Opacity="0.7">
                                <TextBlock Text="{Binding Children.Count}"
                                           Foreground="White"
                                           FontSize="20"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="4"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" Margin="0" ClipToBounds="False"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <Interaction.Behaviors>
                <ExecuteCommandOnDoubleTappedBehavior Command="{Binding OpenSelectedAlbumCommand}"
                                                      CommandParameter="{Binding SelectedAlbum}"/>
                <behaviors:ListboxItemDragBehavior />
            </Interaction.Behaviors>
        </ListBox>
    </Grid>
</UserControl>
